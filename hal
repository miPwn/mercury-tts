#!/bin/bash

# HAL Voice Command Script
# Usage: hal 'sentence one' 'sentence two' 'sentence three'
# OR:    hal "single long sentence with periods and URLs like example.com"
# Handles multiple arguments as separate sentences for optimal TTS processing

SCRIPT_SELF="${BASH_SOURCE[0]:-$0}"
if command -v realpath >/dev/null 2>&1; then
    SCRIPT_SELF=$(realpath "$SCRIPT_SELF" 2>/dev/null || printf '%s' "$SCRIPT_SELF")
fi
SCRIPT_DIR=$(cd -- "$(dirname -- "$SCRIPT_SELF")" && pwd)
VERSION_FILE="${HAL_VERSION_FILE:-$SCRIPT_DIR/.hal-version}"
TTS_ENDPOINT="${HAL_TTS_ENDPOINT:-http://localhost:8091/speak}"
TTS_HEALTH_ENDPOINT="${HAL_TTS_HEALTH_ENDPOINT:-http://localhost:8091/health}"
SPEAKER="${HAL_TTS_SPEAKER:-${HAL_SPEAKER:-p254}}"

print_version() {
    if [ -f "$VERSION_FILE" ]; then
        cat "$VERSION_FILE"
        return
    fi
    printf '%s\n' "${HAL_SERVICE_VERSION:-dev}"
}

if [ "${1:-}" = "--version" ] || [ "${1:-}" = "version" ]; then
    print_version
    exit 0
fi

if [ $# -eq 0 ]; then
    echo "Usage: hal 'your text here'"
    echo "       hal 'sentence one' 'sentence two' 'sentence three'"
    echo "       hal \"Long sentence with URLs like example.com and other content\""
    echo ""
    echo "Multiple arguments are treated as separate sentences for optimal"
    echo "concurrent generation with sequential playback coordination."
    exit 1
fi

# Check TTS service health first
if ! curl -s --max-time 2 "$TTS_HEALTH_ENDPOINT" >/dev/null 2>&1; then
    echo "Error: HAL TTS service not available at $TTS_HEALTH_ENDPOINT"
    exit 1
fi

# Build JSON array from all arguments (each argument is a sentence)
# This enables concurrent generation across multiple TTS endpoints
JSON_SENTENCES="["
FIRST=true

# Process all arguments as separate sentences
for sentence in "$@"; do
    # Skip empty arguments
    if [ -n "$sentence" ]; then
        if [ "$FIRST" = true ]; then
            FIRST=false
        else
            JSON_SENTENCES+=","
        fi
        # Properly escape quotes and special characters for JSON
        escaped_sentence=$(echo "$sentence" | sed 's/\\/\\\\/g; s/"/\\\"/g')
        JSON_SENTENCES+="\"$escaped_sentence\""
    fi
done

JSON_SENTENCES+="]"

# Create complete JSON payload
JSON_PAYLOAD="{\"sentences\":$JSON_SENTENCES,\"speaker\":\"$SPEAKER\"}"

# Send to HAL TTS service with latency optimization
curl -X POST "$TTS_ENDPOINT" \
    -H "Content-Type: application/json" \
    -d "$JSON_PAYLOAD" \
    -s -w "\n" | jq -r '.message // "Request processed"' 2>/dev/null

# Exit successfully
exit 0
