resolve_cached_text_for_audio_file() {
    local audio_file="$1"
    local text_file

    text_file="${audio_file%.wav}.txt"
    if [ -s "$text_file" ]; then
        cat "$text_file"
    fi
}

queue_audio_file_for_playback() {
    local audio_file="$1"
    local spoken_text="$2"
    local response_file http_code response_body

    if [ ! -s "$audio_file" ]; then
        echo "  Error: Audio file not found for queued playback: $audio_file" >&2
        return 1
    fi

    if [ -z "$spoken_text" ]; then
        spoken_text=$(resolve_cached_text_for_audio_file "$audio_file")
    fi

    if [ -z "$spoken_text" ]; then
        echo "  Error: No companion text metadata found for queued playback: $audio_file" >&2
        return 1
    fi

    response_file=$(mktemp /tmp/halo_queue_XXXXXX.json) || return 1
    http_code=$(curl -sS \
        --connect-timeout "$HALO_PLAYBACK_QUEUE_CONNECT_TIMEOUT" \
        --max-time "$HALO_PLAYBACK_QUEUE_MAX_TIME" \
        -o "$response_file" \
        -w "%{http_code}" \
        --form-string "text=$spoken_text" \
        -F "wav=@${audio_file};type=audio/wav" \
        "$HALO_PLAYBACK_QUEUE_ENDPOINT") || {
        rm -f "$response_file"
        return 1
    }

    if [ "$http_code" != "200" ]; then
        response_body=$(tr -d '\r' < "$response_file" 2>/dev/null)
        rm -f "$response_file"
        echo "  Error: Queue playback request returned HTTP ${http_code}: ${response_body}" >&2
        return 1
    fi

    rm -f "$response_file"
    return 0
}

queue_dotmatrix_visualization() {
    local audio_file="$1"
    local spoken_text="${2:-}"
    local trigger_command=""

    if [ "$HALO_DOTMATRIX_ENABLED" != "1" ] || [ ! -s "$audio_file" ]; then
        return 0
    fi

    if command -v "$HALO_DOTMATRIX_TRIGGER_COMMAND" >/dev/null 2>&1; then
        trigger_command="$HALO_DOTMATRIX_TRIGGER_COMMAND"
    elif [ -x "$HALO_DOTMATRIX_VENV_TRIGGER_COMMAND" ]; then
        trigger_command="$HALO_DOTMATRIX_VENV_TRIGGER_COMMAND"
    fi

    if [ -n "$trigger_command" ]; then
        "$trigger_command" trigger --wav-path "$audio_file" --text "$spoken_text" --queue-dir "$HALO_DOTMATRIX_QUEUE_DIR" >/dev/null 2>&1 &
        return 0
    fi

    if command -v "$HALO_SENSORY_PYTHON" >/dev/null 2>&1; then
        "$HALO_SENSORY_PYTHON" -m idotmatrix.halo_display_cli trigger --wav-path "$audio_file" --text "$spoken_text" --queue-dir "$HALO_DOTMATRIX_QUEUE_DIR" >/dev/null 2>&1 &
    fi
}

play_audio_file() {
    local audio_file="$1"
    local spoken_text="${2:-}"
    local playback_started_ms dispatch_ms

    playback_started_ms=$(now_ms)

    if queue_playback_service_available; then
        if queue_audio_file_for_playback "$audio_file" "$spoken_text"; then
            dispatch_ms=$(safe_duration_ms "$playback_started_ms" "$(now_ms)")
            LATENCY_PLAYBACK_DISPATCH_MS="$(( ${LATENCY_PLAYBACK_DISPATCH_MS:-0} + dispatch_ms ))"
            LATENCY_PLAYBACK_PATH="queued"
            echo "  Playback: queued"
            return 0
        fi
        echo "  Playback: local fallback" >&2
    elif [ "$HALO_PLAYBACK_MODE" != "direct" ]; then
        echo "  Playback: local fallback" >&2
    fi

    if [ "$HALO_PLAYBACK_MODE" = "direct" ]; then
        LATENCY_PLAYBACK_PATH="local"
    else
        LATENCY_PLAYBACK_PATH="local_fallback"
    fi
    echo "  Playback: local"
    queue_dotmatrix_visualization "$audio_file" "$spoken_text"
    play_audio_file_direct "$audio_file"
    dispatch_ms=$(safe_duration_ms "$playback_started_ms" "$(now_ms)")
    LATENCY_PLAYBACK_DISPATCH_MS="$(( ${LATENCY_PLAYBACK_DISPATCH_MS:-0} + dispatch_ms ))"
}

story_playlist_is_complete() {
    local manifest_path="$1"
    local cache_path text_path

    if [ ! -s "$manifest_path" ]; then
        return 1
    fi

    while IFS= read -r cache_path; do
        if [ -z "$cache_path" ]; then
            return 1
        fi
        text_path="${cache_path%.wav}.txt"
        if [ ! -s "$cache_path" ] || [ ! -s "$text_path" ]; then
            return 1
        fi
    done < "$manifest_path"

    return 0
}

play_story_playlist() {
    local manifest_path="$1"
    local total_chunks current_chunk cache_path

    total_chunks=$(wc -l < "$manifest_path" | tr -d ' ')
    current_chunk=0

    while IFS= read -r cache_path; do
        if [ -z "$cache_path" ]; then
            continue
        fi
        current_chunk=$(( current_chunk + 1 ))
        if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ] && [ "$total_chunks" -gt 1 ]; then
            echo "  Playing story segment ${current_chunk}/${total_chunks}..."
        fi
        play_audio_file "$cache_path" || return 1
    done < "$manifest_path"

    return 0
}

append_trailing_silence() {
    local wav_file="$1"
    local silence_ms="$2"

    python3 - "$wav_file" "$silence_ms" <<'PY'
import pathlib
import sys
import wave

wav_path = pathlib.Path(sys.argv[1])
silence_ms = int(sys.argv[2])

if silence_ms <= 0:
    raise SystemExit(0)

with wave.open(str(wav_path), 'rb') as source:
    params = source.getparams()
    frames = source.readframes(source.getnframes())

frame_rate = params.framerate
frame_width = params.sampwidth * params.nchannels
silence_frames = max(1, int(frame_rate * silence_ms / 1000))
silence = b'\x00' * (silence_frames * frame_width)

with wave.open(str(wav_path), 'wb') as target:
    target.setparams(params)
    target.writeframes(frames)
    target.writeframes(silence)
PY
}

parse_storygen_args() {
    STORYGEN_RENDER_CACHE_MODE=false
    STORYGEN_MAX_WORDS=""
    STORYGEN_TOPIC=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -rc)
                STORYGEN_RENDER_CACHE_MODE=true
                ;;
            -mw)
                shift
                if [ -z "${1:-}" ]; then
                    echo "Error: -mw requires a positive integer value."
                    exit 1
                fi
                if ! [[ "$1" =~ ^[0-9]+$ ]] || [ "$1" -le 0 ]; then
                    echo "Error: -mw requires a positive integer value."
                    exit 1
                fi
                STORYGEN_MAX_WORDS="$1"
                ;;
            *)
                if [ -n "$STORYGEN_TOPIC" ]; then
                    STORYGEN_TOPIC="$STORYGEN_TOPIC $1"
                else
                    STORYGEN_TOPIC="$1"
                fi
                ;;
        esac
        shift
    done

    if [ "$STORYGEN_RENDER_CACHE_MODE" = true ] && { [ -n "$STORYGEN_MAX_WORDS" ] || [ -n "$STORYGEN_TOPIC" ]; }; then
        echo "Error: -rc cannot be combined with -mw or a story topic." >&2
        exit 1
    fi
}

