evaluate_aware_triggers() {
    local trigger_file memory_db
    trigger_file="${HALO_AWARE_TRIGGER_CONFIG:-$AWARE_TRIGGER_CONFIG_DEFAULT}"
    memory_db="${HALO_AWARE_MEMORY_DB:-$AWARE_MEMORY_DB_DEFAULT}"
    ensure_aware_dirs

    python3 - "$trigger_file" "$memory_db" <<'PY'
import datetime
import json
import pathlib
import random
import sqlite3
import sys

trigger_file = pathlib.Path(sys.argv[1])
memory_db = pathlib.Path(sys.argv[2])

if not trigger_file.exists():
    raise SystemExit(0)

payload = json.loads(trigger_file.read_text(encoding='utf-8'))
triggers = payload.get('triggers', [])
connection = None
if memory_db.exists():
    connection = sqlite3.connect(memory_db)
    connection.row_factory = sqlite3.Row

def last_trigger_time(trigger_id: str):
    if connection is None:
        return None
    try:
        row = connection.execute(
            'SELECT created_at FROM aware_outputs WHERE trigger_id = ? ORDER BY created_at DESC LIMIT 1',
            (trigger_id,),
        ).fetchone()
    except sqlite3.Error:
        return None
    if not row:
        return None
    try:
        return datetime.datetime.fromisoformat(row['created_at'].replace('Z', '+00:00'))
    except Exception:
        return None

now = datetime.datetime.now(datetime.timezone.utc)
selected = None
for trigger in triggers:
    if not trigger.get('enabled'):
        continue

    trigger_type = trigger.get('type')
    trigger_id = trigger.get('id') or 'unnamed-trigger'
    kind = trigger.get('kind') or 'observation'
    topic = trigger.get('topic') or ''

    if trigger_type == 'interval':
        interval_seconds = int(trigger.get('interval_seconds', 0) or 0)
        if interval_seconds <= 0:
            continue
        last_time = last_trigger_time(trigger_id)
        if last_time is None or (now - last_time).total_seconds() >= interval_seconds:
            selected = {
                'kind': kind,
                'topic': topic,
                'trigger_source': 'interval',
                'trigger_id': trigger_id,
            }
            break

    if trigger_type == 'random_chance':
        chance = float(trigger.get('chance', 0) or 0)
        if chance <= 0:
            continue
        if random.random() <= chance:
            selected = {
                'kind': kind,
                'topic': topic,
                'trigger_source': 'random_chance',
                'trigger_id': trigger_id,
            }
            break

if connection is not None:
    connection.close()

if selected:
    print(json.dumps(selected))
PY
}

execute_aware_generation() {
    local kind="$1"
    local topic="$2"
    local trigger_source="$3"
    local trigger_id="$4"
    local output_text artifact_path

    if ! aware_mode_is_enabled; then
        echo "Error: HAL aware mode is OFF. Enable it with: halo aware on" >&2
        return 1
    fi

    aware_notice "HAL aware generation requested"
    aware_notice "  Kind: ${kind}"
    aware_notice "  Trigger: ${trigger_source}"
    if [ -n "$topic" ]; then
        aware_notice "  Topic: ${topic}"
    fi

    output_text=$(generate_aware_text "$kind" "$topic" "$trigger_source") || return 1
    artifact_path=$(store_aware_output_artifact "$kind" "$topic" "$output_text") || return 1
    record_aware_output "$kind" "$topic" "$trigger_source" "$trigger_id" "$output_text" "$artifact_path" || return 1
    refresh_aware_summary || return 1

    printf 'HAL aware output saved: %s\n\n%s\n' "$artifact_path" "$output_text"
}

handle_aware_tick() {
    local trigger_payload trigger_kind trigger_topic trigger_source trigger_id

    if ! aware_mode_is_enabled; then
        echo "Error: HAL aware mode is OFF. Enable it with: halo aware on" >&2
        return 1
    fi

    trigger_payload=$(evaluate_aware_triggers)
    if [ -z "$trigger_payload" ]; then
        echo "No aware triggers fired."
        return 0
    fi

    trigger_kind=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("kind", "observation"), end="")') || return 1
    trigger_topic=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("topic", ""), end="")') || return 1
    trigger_source=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("trigger_source", "tick"), end="")') || return 1
    trigger_id=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("trigger_id", "tick-trigger"), end="")') || return 1

    execute_aware_generation "$trigger_kind" "$trigger_topic" "$trigger_source" "$trigger_id"
}

handle_aware_command() {
    case "$AWARE_ACTION" in
        on)
            set_aware_mode_state true
            echo "HAL aware mode enabled."
            ;;
        off)
            set_aware_mode_state false
            echo "HAL aware mode disabled."
            ;;
        status)
            show_aware_status
            ;;
        trigger)
            execute_aware_generation "$AWARE_TRIGGER_KIND" "$AWARE_TOPIC" "$AWARE_TRIGGER_SOURCE" "$AWARE_TRIGGER_ID"
            ;;
        tick)
            handle_aware_tick
            ;;
        *)
            usage
            return 1
            ;;
    esac
}

handle_sensory_command() {
    local module_root args response should_generate reason topic fingerprint trigger_key summary metadata_json

    module_root="$HALO_SCRIPT_DIR"
    args=("$HALO_SENSORY_PYTHON" -m sensory.cli --halo-root "$HALO_ROOT")

    case "$SENSORY_ACTION" in
        status)
            args+=(status)
            ;;
        scan)
            args+=(scan "$SENSORY_SENSOR")
            ;;
        commentary)
            response=$(PYTHONPATH="$module_root${PYTHONPATH:+:$PYTHONPATH}" "$HALO_SENSORY_PYTHON" -m sensory.cli --halo-root "$HALO_ROOT" commentary "$SENSORY_SENSOR") || return 1
            printf '%s\n' "$response"

            should_generate=$(printf '%s' "$response" | python3 -c 'import json, sys; print("1" if json.load(sys.stdin).get("should_generate") else "0", end="")') || return 1
            if [ "$should_generate" != "1" ]; then
                return 0
            fi

            if ! aware_mode_is_enabled; then
                echo "HAL aware mode is OFF; sensory commentary candidate recorded but not expanded." >&2
                return 0
            fi

            topic=$(printf '%s' "$response" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("candidate", {}).get("topic", ""), end="")') || return 1
            fingerprint=$(printf '%s' "$response" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("candidate", {}).get("fingerprint", ""), end="")') || return 1
            trigger_key=$(printf '%s' "$response" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("trigger_key", ""), end="")') || return 1
            summary=$(printf '%s' "$response" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("candidate", {}).get("summary", ""), end="")') || return 1
            metadata_json=$(printf '%s' "$response" | python3 -c 'import json, sys; print(json.dumps({"sensor": json.load(sys.stdin).get("sensor_name", "all")}), end="")') || return 1

            execute_aware_generation "observation" "$topic" "$trigger_key" "$fingerprint" || return 1
            PYTHONPATH="$module_root${PYTHONPATH:+:$PYTHONPATH}" "$HALO_SENSORY_PYTHON" -m sensory.cli --halo-root "$HALO_ROOT" mark-commentary --trigger-key "$trigger_key" --fingerprint "$fingerprint" --summary "$summary" --metadata-json "$metadata_json" >/dev/null || return 1
            return 0
            ;;
        *)
            usage
            return 1
            ;;
    esac

    PYTHONPATH="$module_root${PYTHONPATH:+:$PYTHONPATH}" "${args[@]}"
}

select_commentary_line() {
    local commentary_file="$1"
    local commentary_db
    commentary_db="${HALO_COMMENTARY_HISTORY_DB:-$COMMENTARY_HISTORY_DB_DEFAULT}"
    mkdir -p "$STATE_DIR"

    python3 - "$commentary_file" "$commentary_db" <<'PY'
import datetime
import hashlib
import pathlib
import random
import sqlite3
import sys

commentary_path = pathlib.Path(sys.argv[1])
db_path = pathlib.Path(sys.argv[2])

lines = []
seen = set()
for raw_line in commentary_path.read_text(encoding='utf-8').splitlines():
    line = raw_line.strip()
    if not line or line in seen:
        continue
    seen.add(line)
    lines.append(line)

if not lines:
    print('No commentary lines available.', file=sys.stderr)
    raise SystemExit(1)

db_path.parent.mkdir(parents=True, exist_ok=True)
connection = sqlite3.connect(db_path)
connection.execute('PRAGMA journal_mode = WAL')
connection.execute('PRAGMA busy_timeout = 5000')
connection.execute(
    '''
    CREATE TABLE IF NOT EXISTS commentary_cycles (
        commentary_file TEXT PRIMARY KEY,
        current_cycle INTEGER NOT NULL DEFAULT 0,
        updated_at TEXT NOT NULL
    )
    '''
)
connection.execute(
    '''
    CREATE TABLE IF NOT EXISTS commentary_history (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        commentary_file TEXT NOT NULL,
        line_hash TEXT NOT NULL,
        line_text TEXT NOT NULL,
        cycle INTEGER NOT NULL,
        played_at TEXT NOT NULL,
        UNIQUE(commentary_file, line_hash, cycle)
    )
    '''
)

commentary_key = str(commentary_path.resolve())
played_at = datetime.datetime.now(datetime.timezone.utc).isoformat()

try:
    connection.execute('BEGIN IMMEDIATE')
    row = connection.execute(
        'SELECT current_cycle FROM commentary_cycles WHERE commentary_file = ?',
        (commentary_key,),
    ).fetchone()
    current_cycle = int(row[0]) if row else 0

    played_hashes = {
        record[0]
        for record in connection.execute(
            'SELECT line_hash FROM commentary_history WHERE commentary_file = ? AND cycle = ?',
            (commentary_key, current_cycle),
        )
    }

    def line_hash(value: str) -> str:
        return hashlib.sha256(value.encode('utf-8')).hexdigest()

    available = [line for line in lines if line_hash(line) not in played_hashes]
    if not available:
        current_cycle += 1
        available = lines[:]

    selected = random.choice(available)
    selected_hash = line_hash(selected)
    connection.execute(
        '''
        INSERT INTO commentary_history (commentary_file, line_hash, line_text, cycle, played_at)
        VALUES (?, ?, ?, ?, ?)
        ''',
        (commentary_key, selected_hash, selected, current_cycle, played_at),
    )
    connection.execute(
        '''
        INSERT INTO commentary_cycles (commentary_file, current_cycle, updated_at)
        VALUES (?, ?, ?)
        ON CONFLICT(commentary_file) DO UPDATE SET
            current_cycle = excluded.current_cycle,
            updated_at = excluded.updated_at
        ''',
        (commentary_key, current_cycle, played_at),
    )
    connection.commit()
finally:
    connection.close()

print(selected)
PY
}

resolve_story_file() {
    local candidate="$1"
    if [ -f "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    if [[ "$candidate" != */* ]]; then
        if [[ "$candidate" != *.txt ]]; then
            candidate="${STORY_DIR}/${candidate}.txt"
        else
            candidate="${STORY_DIR}/${candidate}"
        fi
    fi
    if [ -f "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

