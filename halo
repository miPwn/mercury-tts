handle_aware_tick() {
    local trigger_payload trigger_kind trigger_topic trigger_source trigger_id

    if ! aware_mode_is_enabled; then
        echo "Error: HAL aware mode is OFF. Enable it with: halo aware on" >&2
        return 1
    fi

    trigger_payload=$(evaluate_aware_triggers)
    if [ -z "$trigger_payload" ]; then
        echo "No aware triggers fired."
        return 0
    fi

    trigger_kind=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("kind", "observation"), end="")') || return 1
    trigger_topic=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("topic", ""), end="")') || return 1
    trigger_source=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("trigger_source", "tick"), end="")') || return 1
    trigger_id=$(printf '%s' "$trigger_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("trigger_id", "tick-trigger"), end="")') || return 1

    execute_aware_generation "$trigger_kind" "$trigger_topic" "$trigger_source" "$trigger_id"
}

