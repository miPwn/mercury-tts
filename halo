build_story_filename() {
    local topic="$1"
    local story_tmp="$2"
    python3 - "$topic" "$story_tmp" <<'PY'
import pathlib
import re
import sys
import unicodedata

topic = sys.argv[1].strip()
story_text = pathlib.Path(sys.argv[2]).read_text(encoding='utf-8').strip()
seed = topic or story_text.splitlines()[0] if story_text else 'story'
seed = unicodedata.normalize('NFKD', seed)
seed = seed.encode('ascii', 'ignore').decode('ascii')
words = re.findall(r'[A-Za-z0-9]+', seed.lower())
stop_words = {
    'a', 'an', 'and', 'are', 'as', 'at', 'be', 'but', 'by', 'do', 'for', 'from', 'have',
    'i', 'in', 'is', 'it', 'its', 'me', 'my', 'of', 'on', 'or', 'that', 'the', 'their',
    'them', 'there', 'they', 'this', 'to', 'was', 'we', 'with', 'you', 'your'
}

preferred = [word for word in words if word not in stop_words]
selected = preferred[:3]
if len(selected) < 2:
    selected = words[:3]
slug = '-'.join(selected[:3]) or 'story'
print(f'{slug[:48]}.txt')
PY
}

store_story_file() {
    local topic="$1"
    local story_tmp="$2"
    local request_format="${3:-story}"
    local filename target output_dir

    case "$request_format" in
        podcast)
            output_dir="${HALO_GENERATED_PODCAST_DIR:-$GENERATED_PODCAST_DIR_DEFAULT}"
            ;;
        story|*)
            output_dir="${HALO_GENERATED_STORY_DIR:-$GENERATED_STORY_DIR_DEFAULT}"
            ;;
    esac
    mkdir -p "$output_dir"
    filename=$(build_story_filename "$topic" "$story_tmp")
    target="$output_dir/$filename"
    if [ -e "$target" ]; then
        target="${target%.txt}__$(date -u +%s).txt"
    fi
    mv "$story_tmp" "$target"
    printf '%s\n' "$target"
}

mark_request_failed() {
    local request_dir="$1"
    local destination="$QUEUE_FAILED_DIR/$(basename "$request_dir")"
    mkdir -p "$destination"
    cp -a "$request_dir/." "$destination/" 2>/dev/null || true
    rm -rf "$request_dir"
}

mark_request_done() {
    local request_dir="$1"
    local destination="$QUEUE_DONE_DIR/$(basename "$request_dir")"
    mkdir -p "$destination"
    cp -a "$request_dir/." "$destination/" 2>/dev/null || true
    rm -rf "$request_dir"
}

process_story_request() {
    local request_dir="$1"
    local topic max_words request_format podcast_minutes story_tmp story_path cache_file_path

    topic=""
    max_words=""
    request_format="story"
    podcast_minutes=""
    if [ -f "$request_dir/topic.txt" ]; then
        topic=$(cat "$request_dir/topic.txt")
    fi
    if [ -f "$request_dir/max_words.txt" ]; then
        max_words=$(tr -d '\r\n' < "$request_dir/max_words.txt")
    fi
    if [ -f "$request_dir/format.txt" ]; then
        request_format=$(tr -d '\r\n' < "$request_dir/format.txt")
    fi
    if [ -f "$request_dir/podcast_minutes.txt" ]; then
        podcast_minutes=$(tr -d '\r\n' < "$request_dir/podcast_minutes.txt")
    fi
    printf '%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$request_dir/started_at.txt"

    story_tmp=$(mktemp "$request_dir/story.XXXXXX.txt") || return 1
    if ! generate_story_text "$topic" "$max_words" "$request_format" "$podcast_minutes" > "$story_tmp" 2> "$request_dir/error.log"; then
        rm -f "$story_tmp"
        printf '%s\n' "generation_failed" > "$request_dir/status.txt"
        mark_request_failed "$request_dir"
        return 1
    fi

    if [ -n "$max_words" ]; then
        python3 - "$story_tmp" "$max_words" <<'PY'
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
max_words = int(sys.argv[2])
text = path.read_text(encoding='utf-8')
tokens = list(re.finditer(r'\S+', text))
if len(tokens) > max_words:
    cutoff = tokens[max_words - 1].end()
    text = text[:cutoff].rstrip()
    path.write_text(text + '\n', encoding='utf-8')
PY
    fi

    if ! python3 - "$story_tmp" <<'PY'
import pathlib
import sys

text = pathlib.Path(sys.argv[1]).read_text(encoding='utf-8')
raise SystemExit(0 if text.strip() else 1)
PY
    then
        rm -f "$story_tmp"
        printf '%s\n' "empty_story" > "$request_dir/status.txt"
        printf '%s\n' "OpenAI returned an empty story." > "$request_dir/error.log"
        mark_request_failed "$request_dir"
        return 1
    fi

    story_path=$(store_story_file "$topic" "$story_tmp" "$request_format") || {
        rm -f "$story_tmp"
        printf '%s\n' "store_failed" > "$request_dir/status.txt"
        mark_request_failed "$request_dir"
        return 1
    }

    if ! cache_file_path=$(bash "$HALO_SELF" --render-only read "$story_path" 2> "$request_dir/render_error.log"); then
        printf '%s\n' "$story_path" > "$request_dir/result_path.txt"
        printf '%s\n' "$(basename "$story_path")" > "$request_dir/result_name.txt"
        printf '%s\n' "render_failed" > "$request_dir/status.txt"
        if [ -s "$request_dir/render_error.log" ]; then
            cp "$request_dir/render_error.log" "$request_dir/error.log" 2>/dev/null || cat "$request_dir/render_error.log" > "$request_dir/error.log"
        else
            printf '%s\n' "Error: story audio render failed for $(basename "$story_path")" > "$request_dir/error.log"
        fi
        mark_request_failed "$request_dir"
        return 1
    fi

    rm -f "$request_dir/render_error.log"

    printf '%s\n' "$story_path" > "$request_dir/result_path.txt"
    printf '%s\n' "$(basename "$story_path")" > "$request_dir/result_name.txt"
    printf '%s\n' "$cache_file_path" > "$request_dir/result_audio_path.txt"
    printf '%s\n' "done" > "$request_dir/status.txt"
    printf '%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$request_dir/finished_at.txt"
    mark_request_done "$request_dir"
    return 0
}

process_storygen_queue() {
    local request_dir processing_dir

    ensure_storygen_dirs
    if ! acquire_queue_lock 0; then
        return 0
    fi

    while true; do
        request_dir=$(find "$QUEUE_PENDING_DIR" -mindepth 1 -maxdepth 1 -type d | sort | head -n 1)
        if [ -z "$request_dir" ]; then
            break
        fi

        processing_dir="$QUEUE_PROCESSING_DIR/$(basename "$request_dir")"
        if ! mv "$request_dir" "$processing_dir" 2>/dev/null; then
            continue
        fi
        process_story_request "$processing_dir" || true
    done

    release_queue_lock
}

run_storygen_queue_child() {
    load_storygen_env
    process_storygen_queue
}

start_storygen_queue_worker() {
    ensure_storygen_dirs
    nohup bash "$HALO_SELF" __process-storygen-queue >/dev/null 2>&1 &
}

wait_for_story_request() {
    local request_id="$1"
    local deadline request_dir state_label last_state last_notice_at now
    deadline=$(( $(date +%s) + HALO_STORYGEN_WAIT_SECONDS ))
    last_state=""
    last_notice_at=0

    while [ "$(date +%s)" -le "$deadline" ]; do
        if request_dir=$(request_state_dir "$request_id"); then
            case "$request_dir" in
                "$QUEUE_PENDING_DIR"/*)
                    state_label="queued"
                    ;;
                "$QUEUE_PROCESSING_DIR"/*)
                    state_label="generating"
                    ;;
                "$QUEUE_DONE_DIR"/*)
                    state_label="done"
                    ;;
                "$QUEUE_FAILED_DIR"/*)
                    state_label="failed"
                    ;;
                *)
                    state_label="unknown"
                    ;;
            esac

            if [ "$state_label" != "$last_state" ]; then
                case "$state_label" in
                    queued)
                        storygen_status "  Queue status: queued"
                        ;;
                    generating)
                        storygen_status "  Queue status: generating story text and audio"
                        ;;
                    done)
                        storygen_status "  Queue status: complete"
                        ;;
                    failed)
                        storygen_status "  Queue status: failed"
                        ;;
                esac
                last_state="$state_label"
                last_notice_at=$(date +%s)
            fi

            case "$request_dir" in
                "$QUEUE_DONE_DIR"/*)
                    cat "$request_dir/result_path.txt"
                    return 0
                    ;;
                "$QUEUE_FAILED_DIR"/*)
                    if [ -f "$request_dir/error.log" ]; then
                        cat "$request_dir/error.log" >&2
                    elif [ -f "$request_dir/render_error.log" ]; then
                        cat "$request_dir/render_error.log" >&2
                    else
                        echo "Error: story generation failed for request $request_id" >&2
                    fi
                    return 1
                    ;;
            esac
        fi
        now=$(date +%s)
        if [ $(( now - last_notice_at )) -ge 10 ]; then
            storygen_status "  Waiting for request $request_id..."
            last_notice_at=$now
        fi
        process_storygen_queue || true
        sleep 1
    done

    echo "Error: timed out waiting for story generation request $request_id" >&2
    return 1
}

handle_storygen() {
    local request_id
    load_storygen_env

    if [ "$STORYGEN_RENDER_CACHE_MODE" = true ]; then
        render_uncached_story_cache
        return $?
    fi

    storygen_status "HALO story generation requested"
    if [ "$STORYGEN_FORMAT" = "podcast" ]; then
        storygen_status "  Format: podcast"
        storygen_status "  Target duration: ${STORYGEN_PODCAST_MINUTES} minutes"
        storygen_status "  Approx words: ${STORYGEN_MAX_WORDS}"
    fi
    if [ -n "$STORYGEN_TOPIC" ]; then
        storygen_status "  Topic: $STORYGEN_TOPIC"
    else
        storygen_status "  Topic: random"
    fi
    if [ -n "$STORYGEN_MAX_WORDS" ] && [ "$STORYGEN_FORMAT" != "podcast" ]; then
