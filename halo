Current UTC timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)
System host: ${host_name}
Trigger source: ${trigger_source}
Requested output kind: ${kind}
Topic seed: ${topic:-none}
EOF
}

build_aware_generation_prompts() {
    local kind="$1"
    local topic="$2"
    local trigger_source="$3"
    local persona_text memory_json runtime_context word_limit

    persona_text=$(load_aware_persona) || return 1
    memory_json=$(select_aware_memory_context "$kind" "$topic" "$trigger_source") || return 1
    runtime_context=$(build_aware_runtime_context "$kind" "$topic" "$trigger_source")
    word_limit=$(aware_output_word_limit "$kind")

    HALO_AWARE_PERSONA_TEXT="$persona_text" \
    HALO_AWARE_MEMORY_JSON="$memory_json" \
    HALO_AWARE_RUNTIME_CONTEXT="$runtime_context" \
    python3 - "$kind" "$topic" "$trigger_source" "$word_limit" <<'PY'
import json
import os
import sys

kind = sys.argv[1]
topic = sys.argv[2]
trigger_source = sys.argv[3]
word_limit = sys.argv[4]

persona = os.environ['HALO_AWARE_PERSONA_TEXT'].strip()
memory = json.loads(os.environ['HALO_AWARE_MEMORY_JSON'])
runtime_context = os.environ['HALO_AWARE_RUNTIME_CONTEXT'].strip()

kind_guidance = {
    'commentary': 'Produce one short piece of commentary. Keep it compact, controlled, and suitable for an aware aside.',
    'observation': 'Produce one reflective observation. It should feel present, attentive, and contextually continuous.',
    'monologue': 'Produce one sustained monologue. It should develop an idea rather than merely state it.',
    'story': 'Produce one short story in HAL\'s voice. It should be self-contained, atmospheric, and narratively coherent.',
}

system_prompt = '\n\n'.join([
    persona,
    'You are operating in HAL aware mode. This is persistent continuity, not a stateless one-off generation.',
    'Treat prior HAL outputs as your own remembered speech and internal record.',
    'Do not repeat yourself lazily. Build continuity, vary focus, and acknowledge earlier ideas only when they remain relevant.',
    'Prefer elegant continuity over recap. Avoid headings, markdown, bullet lists, and code fences.',
    f'Output kind: {kind}. Word limit: {word_limit}.',
])

recent_lines = []
for item in memory.get('recent', []):
    topic_suffix = f' | topic: {item.get("topic")}' if item.get('topic') else ''
    recent_lines.append(f'- {item.get("created_at")} | {item.get("kind")} | trigger: {item.get("trigger_source")}{topic_suffix} | {item.get("summary_snippet")}')

relevant_lines = []
for item in memory.get('relevant', []):
    topic_suffix = f' | topic: {item.get("topic")}' if item.get('topic') else ''
    relevant_lines.append(f'- {item.get("created_at")} | {item.get("kind")} | trigger: {item.get("trigger_source")}{topic_suffix} | {item.get("summary_snippet")}')

user_parts = [
    runtime_context,
    f'Requested content type: {kind}',
    f'Trigger source: {trigger_source}',
    f'Topic seed: {topic or "none"}',
    kind_guidance.get(kind, kind_guidance['observation']),
    f'Keep the response within approximately {word_limit} words.',
]

if memory.get('summary'):
    user_parts.extend(['', 'Continuity summary:', memory['summary']])

if recent_lines:
    user_parts.extend(['', 'Recent HAL outputs:', '\n'.join(recent_lines)])

if relevant_lines:
    user_parts.extend(['', 'Relevant older HAL outputs:', '\n'.join(relevant_lines)])

user_parts.extend([
    '',
    'Write one new output that feels like the next thought from an ongoing mind. Use continuity, but do not quote or recycle earlier lines verbatim unless there is a clear deliberate reason.',
])

print(json.dumps({
    'system_prompt': system_prompt,
    'user_prompt': '\n'.join(user_parts).strip(),
}))
PY
}

generate_aware_text() {
    local kind="$1"
    local topic="$2"
    local trigger_source="$3"
    local prompt_payload system_prompt user_prompt

    load_storygen_env
    prompt_payload=$(build_aware_generation_prompts "$kind" "$topic" "$trigger_source") || return 1
    system_prompt=$(printf '%s' "$prompt_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin)["system_prompt"], end="")') || return 1
    user_prompt=$(printf '%s' "$prompt_payload" | python3 -c 'import json, sys; print(json.load(sys.stdin)["user_prompt"], end="")') || return 1
    generate_openai_text "$system_prompt" "$user_prompt" 180
}

store_aware_output_artifact() {
    local kind="$1"
    local topic="$2"
    local text="$3"
    local output_dir
    output_dir="${HALO_AWARE_OUTPUT_DIR:-$AWARE_OUTPUT_DIR_DEFAULT}"
    ensure_aware_dirs

    HALO_AWARE_ARTIFACT_TEXT="$text" python3 - "$output_dir" "$kind" "$topic" <<'PY'
import datetime
import os
import pathlib
import re
import sys
import unicodedata

output_dir = pathlib.Path(sys.argv[1])
kind = sys.argv[2]
topic = sys.argv[3].strip()
text = os.environ['HALO_AWARE_ARTIFACT_TEXT'].strip()

def slugify(value: str) -> str:
    normalized = unicodedata.normalize('NFKD', value or '')
    ascii_text = normalized.encode('ascii', 'ignore').decode('ascii')
    words = re.findall(r'[A-Za-z0-9]+', ascii_text.lower())
    return '-'.join(words[:4]) or 'untitled'

stamp = datetime.datetime.now(datetime.timezone.utc).strftime('%Y%m%dT%H%M%S%fZ')
topic_slug = slugify(topic)
artifact_path = output_dir / f'{stamp}-{kind}-{topic_slug}.txt'
content = '\n'.join([
    f'kind: {kind}',
    f'topic: {topic or "none"}',
    f'created_at: {datetime.datetime.now(datetime.timezone.utc).isoformat()}',
    '',
    text,
]) + '\n'
artifact_path.write_text(content, encoding='utf-8')
print(artifact_path)
PY
}

