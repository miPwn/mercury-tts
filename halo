    fi
}

resolve_halo_persona_file() {
    local prompt_file legacy_file

    if [ -n "${HALO_PERSONA_PROMPT_FILE:-}" ]; then
        printf '%s\n' "$HALO_PERSONA_PROMPT_FILE"
        return 0
    fi
    if [ -n "${HALO_AWARE_PERSONA_FILE:-}" ]; then
        printf '%s\n' "$HALO_AWARE_PERSONA_FILE"
        return 0
    fi

    prompt_file="$HALO_PERSONA_PROMPT_FILE_DEFAULT"
    legacy_file="$HALO_PERSONA_LEGACY_FILE_DEFAULT"

    if [ -f "$prompt_file" ]; then
        printf '%s\n' "$prompt_file"
        return 0
    fi
    printf '%s\n' "$legacy_file"
}

load_halo_persona() {
