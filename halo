finally:
    connection.close()

lines = [
    'HAL aware continuity digest',
    'Use this as compressed memory, not as an exhaustive transcript.',
    '',
]

for row in rows:
    topic_suffix = f' | topic: {row["topic"]}' if row['topic'] else ''
    lines.append(f'- {row["created_at"]} | {row["kind"]} | trigger: {row["trigger_source"]}{topic_suffix}')
    lines.append(f'  {row["summary_snippet"]}')

text = '\n'.join(lines).strip() + '\n'
if len(text) > max_chars:
    text = text[:max_chars].rstrip() + '\n'

summary_file.write_text(text, encoding='utf-8')
PY
}

