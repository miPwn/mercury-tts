safe_duration_ms() {
    local start="$1"
    local finish="$2"

    if [ -z "$start" ] || [ -z "$finish" ]; then
        printf '0\n'
        return 0
    fi

    if [ "$finish" -lt "$start" ]; then
        printf '0\n'
        return 0
    fi

    printf '%s\n' "$(( finish - start ))"
}

