show_storygen_queue_viewer() {
    ensure_storygen_dirs
    python3 - "$QUEUE_PENDING_DIR" "$QUEUE_PROCESSING_DIR" "$QUEUE_DONE_DIR" "$QUEUE_FAILED_DIR" "$QUEUE_LOCK_DIR" <<'PY'
import datetime as dt
import os
import pathlib
import shutil
import signal
import sys
import time

pending_dir = pathlib.Path(sys.argv[1])
processing_dir = pathlib.Path(sys.argv[2])
done_dir = pathlib.Path(sys.argv[3])
failed_dir = pathlib.Path(sys.argv[4])
lock_dir = pathlib.Path(sys.argv[5])

running = True


def stop(_signum, _frame):
    global running
    running = False


for sig in (signal.SIGINT, signal.SIGTERM):
    signal.signal(sig, stop)


def safe_read(path: pathlib.Path) -> str:
    try:
        return path.read_text(encoding='utf-8').strip()
    except Exception:
        return ''


def request_rows(root: pathlib.Path):
    rows = []
    if not root.exists():
        return rows
    for entry in sorted((p for p in root.iterdir() if p.is_dir()), key=lambda p: p.name):
        rows.append(
            {
                'id': entry.name,
                'topic': safe_read(entry / 'topic.txt') or 'random',
                'created_at': safe_read(entry / 'created_at.txt'),
                'started_at': safe_read(entry / 'started_at.txt'),
                'finished_at': safe_read(entry / 'finished_at.txt'),
                'status': safe_read(entry / 'status.txt'),
                'error': safe_read(entry / 'error.log').splitlines()[:1],
                'path': entry,
            }
        )
    return rows


def rel_time(raw: str) -> str:
    if not raw:
        return '-'
    try:
        when = dt.datetime.fromisoformat(raw.replace('Z', '+00:00'))
        delta = dt.datetime.now(dt.timezone.utc) - when
        seconds = max(0, int(delta.total_seconds()))
        if seconds < 60:
            return f'{seconds}s ago'
        if seconds < 3600:
            return f'{seconds // 60}m ago'
        if seconds < 86400:
            return f'{seconds // 3600}h ago'
        return f'{seconds // 86400}d ago'
    except Exception:
        return raw


def status_color(label: str) -> str:
    mapping = {
        'queued': '\033[33m',
        'generating': '\033[36m',
        'done': '\033[32m',
        'failed': '\033[31m',
        'generation_failed': '\033[31m',
        'render_failed': '\033[31m',
        'store_failed': '\033[31m',
        'empty_story': '\033[31m',
    }
    return mapping.get(label, '\033[90m')


def truncate(value: str, width: int) -> str:
    if width <= 0:
        return ''
    if len(value) <= width:
        return value
    if width <= 3:
        return value[:width]
    return value[: width - 3] + '...'


def row_line(label: str, item: dict, width: int) -> str:
    topic = truncate(item['topic'], max(12, width - 42))
    age = rel_time(item['started_at'] or item['created_at'])
    status = item['status'] or label
    color = status_color(status)
    return f"  {color}{status.upper():<12}\033[0m {item['id']:<31} {age:<10} {topic}"


def render_section(title: str, label: str, items: list[dict], width: int, limit: int) -> list[str]:
    lines = [f'  {title} ({len(items)})']
    if not items:
        lines.append('    none')
        return lines
    for item in items[:limit]:
        lines.append(row_line(label, item, width))
        if item['error']:
            lines.append('      ' + truncate(item['error'][0], max(20, width - 8)))
    return lines


def snapshot():
    pending = request_rows(pending_dir)
    processing = request_rows(processing_dir)
    done = list(reversed(request_rows(done_dir)))
    failed = list(reversed(request_rows(failed_dir)))
    lock_owner = safe_read(lock_dir / 'pid') if lock_dir.exists() else ''
    return pending, processing, done, failed, lock_owner


sys.stdout.write('\033[?1049h\033[?25l')
sys.stdout.flush()

try:
    while running:
        width = max(80, shutil.get_terminal_size((120, 40)).columns)
        height = max(24, shutil.get_terminal_size((120, 40)).lines)
        pending, processing, done, failed, lock_owner = snapshot()
        now = dt.datetime.now().astimezone().strftime('%Y-%m-%d %H:%M:%S %Z')
        limit = max(2, (height - 16) // 4)

        lines = [
            '\033[2J\033[H',
            ' HALO STORYGEN QUEUE VIEWER',
            f' {now}',
            '',
            f'  Pending: {len(pending):<4} Processing: {len(processing):<4} Done: {len(done):<4} Failed: {len(failed):<4} Lock: {lock_owner or "idle"}',
            '',
        ]
        lines.extend(render_section('Processing', 'generating', processing, width, limit))
        lines.append('')
        lines.extend(render_section('Pending', 'queued', pending, width, limit))
        lines.append('')
        lines.extend(render_section('Recent Done', 'done', done, width, limit))
        lines.append('')
        lines.extend(render_section('Recent Failed', 'failed', failed, width, limit))
        lines.append('')
        lines.append('  Ctrl-C to exit viewer')

        sys.stdout.write('\n'.join(lines))
        sys.stdout.flush()
        time.sleep(1)
finally:
    sys.stdout.write('\033[0m\033[?25h\033[?1049l')
    sys.stdout.flush()
PY
}

now_ms() {
