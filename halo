) || return 1

    content_format=$(storygen_format_for_file "$story_file") || return 1
    bundle_dir=$(bundle_dir_for_format "$content_format" "$story_hash") || return 1
    case "$content_format" in
        podcast)
            cache_category="podcast-bundle"
            content_label="Podcast"
            ;;
        story|*)
            cache_category="story-bundle"
            content_label="Story"
            ;;
    esac

    chunk_dir=$(mktemp -d "${STATE_DIR}/story-read.XXXXXX") || return 1
    mkdir -p "$bundle_dir"
    manifest_path="${bundle_dir}/playlist.txt"
    manifest_tmp="${manifest_path}.tmp"

    if story_playlist_is_complete "$manifest_path"; then
        schedule_story_bundle_assembly "$story_file" "$manifest_path" || true
        if [ "$RENDER_ONLY" = true ]; then
            printf '%s\n' "$manifest_path"
        else
            chunk_count=$(grep -cve '^[[:space:]]*$' "$manifest_path" 2>/dev/null || printf '0')
            LATENCY_CACHE_HIT="true"
            LATENCY_RENDER_ROUTE="cache"
            LATENCY_CHUNK_COUNT="$chunk_count"
            echo "HALO reading: $story_file"
            echo "  ${content_label} playlist cache hit"
            play_story_playlist "$manifest_path" || return 1
            persist_latency_snapshot
            echo "HALO processing complete."
        fi
        return 0
    fi

    if ! chunk_count=$(split_story_into_chunks "$story_file" "$chunk_dir"); then
        rm -rf "$chunk_dir"
        return 1
    fi

    if [ "$chunk_count" -le 0 ]; then
        rm -rf "$chunk_dir"
        return 1
    fi

    : > "$manifest_tmp"

    if [ "$RENDER_ONLY" = false ]; then
        LATENCY_CHUNK_COUNT="$chunk_count"
        LATENCY_RENDER_ROUTE="unknown"
        echo "HALO reading: $story_file"
        echo "  Chunking story into ${chunk_count} segments for XTTS..."
    fi

    while IFS= read -r -d '' chunk_file; do
        chunk_text=$(python3 -c 'import pathlib, sys; print(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").strip(), end="")' "$chunk_file")
        if [ -z "$chunk_text" ]; then
            continue
        fi

        chunk_render_started_ms=$(now_ms)
        chunk_route_file=$(mktemp "${STATE_DIR}/story-route.XXXXXX") || {
            rm -f "$manifest_tmp"
            rm -rf "$chunk_dir"
            return 1
        }
        cache_path=$(HALO_INTERNAL_READ_CHILD=1 HALO_INTERNAL_LATENCY_CHILD=1 HALO_INTERNAL_ROUTE_FILE="$chunk_route_file" HALO_TTS_REQUEST_CLASS=story HALO_TTS_CACHE_CATEGORY="$cache_category" HALO_TTS_CACHE_BUNDLE_DIR="$bundle_dir" bash "$HALO_SELF" --render-only "$chunk_text") || {
            rm -f "$chunk_route_file"
            rm -f "$manifest_tmp"
            rm -rf "$chunk_dir"
            return 1
        }
        observed_route=$(tr -d '\r\n' < "$chunk_route_file" 2>/dev/null || true)
        rm -f "$chunk_route_file"
        LATENCY_RENDER_ROUTE=$(merge_render_route_label "$LATENCY_RENDER_ROUTE" "$observed_route")
        LATENCY_RENDER_REQUEST_MS="$(( ${LATENCY_RENDER_REQUEST_MS:-0} + $(safe_duration_ms "$chunk_render_started_ms" "$(now_ms)") ))"
        manifest_text=$(printf '%s' "$chunk_text" | tr '\t\r\n' '   ')
        printf '%s\t%s\n' "$cache_path" "$manifest_text" >> "$manifest_tmp"

        if [ "$RENDER_ONLY" = false ]; then
            play_audio_file "$cache_path" "$chunk_text" || {
                rm -f "$manifest_tmp"
                rm -rf "$chunk_dir"
                return 1
            }
        fi
    done < <(find "$chunk_dir" -maxdepth 1 -type f -name 'chunk-*.txt' -print0 | sort -z)

    rm -rf "$chunk_dir"

    mv "$manifest_tmp" "$manifest_path"
    schedule_story_bundle_assembly "$story_file" "$manifest_path" || true

    if [ "$RENDER_ONLY" = true ]; then
        printf '%s\n' "$manifest_path"
    else
        persist_latency_snapshot
        echo "HALO processing complete."
    fi
}

generate_request_id() {
    printf '%s-%s-%s\n' "$(date -u +%Y%m%d-%H%M%S)" "$$" "$(python3 -c 'import uuid; print(uuid.uuid4().hex[:8])')"
}

request_state_dir() {
    local request_id="$1"
    local directory
    for directory in "$QUEUE_PENDING_DIR" "$QUEUE_PROCESSING_DIR" "$QUEUE_DONE_DIR" "$QUEUE_FAILED_DIR"; do
        if [ -d "$directory/$request_id" ]; then
            printf '%s\n' "$directory/$request_id"
            return 0
        fi
    done
    return 1
}

acquire_queue_lock() {
    local wait_seconds="${1:-0}"
    local start_time current_time lock_pid lock_age
    start_time=$(date +%s)
    while true; do
        if mkdir "$QUEUE_LOCK_DIR" 2>/dev/null; then
            printf '%s\n' "$$" > "$QUEUE_LOCK_DIR/pid"
            return 0
        fi

        lock_pid=""
        if [ -f "$QUEUE_LOCK_DIR/pid" ]; then
            lock_pid=$(tr -d '\r\n' < "$QUEUE_LOCK_DIR/pid" 2>/dev/null)
        fi
        lock_age=$(( $(date +%s) - $(stat -c %Y "$QUEUE_LOCK_DIR" 2>/dev/null || echo 0) ))
        if [ -z "$lock_pid" ] || ! kill -0 "$lock_pid" 2>/dev/null || [ "$lock_age" -gt 1800 ]; then
            rm -rf "$QUEUE_LOCK_DIR"
            continue
        fi

        current_time=$(date +%s)
        if [ $(( current_time - start_time )) -ge "$wait_seconds" ]; then
            return 1
        fi
        sleep 1
    done
}

release_queue_lock() {
    if [ -d "$QUEUE_LOCK_DIR" ] && [ -f "$QUEUE_LOCK_DIR/pid" ]; then
        if [ "$(tr -d '\r\n' < "$QUEUE_LOCK_DIR/pid" 2>/dev/null)" = "$$" ]; then
            rm -rf "$QUEUE_LOCK_DIR"
        fi
    fi
}

