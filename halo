build_generation_memory_context() {
    local generated_dir aware_output_dir commentary_db

    generated_dir="${HALO_GENERATED_STORY_DIR:-$GENERATED_STORY_DIR_DEFAULT}"
    aware_output_dir="${HALO_AWARE_OUTPUT_DIR:-$AWARE_OUTPUT_DIR_DEFAULT}"
    commentary_db="${HALO_COMMENTARY_HISTORY_DB:-$COMMENTARY_HISTORY_DB_DEFAULT}"

    python3 - "$generated_dir" "$aware_output_dir" "$commentary_db" "$HALO_GENERATION_MEMORY_MAX_CHARS" "$HALO_GENERATION_MEMORY_MAX_ENTRIES" "${HALO_GENERATION_MEMORY_SECTION_PROMPT_FILE:-$GENERATION_MEMORY_SECTION_PROMPT_FILE_DEFAULT}" <<'PY'
import datetime
import hashlib
import json
import pathlib
import sqlite3
import sys


def load_prompt_text(path_text, fallback):
    path = pathlib.Path(path_text)
    try:
        return path.read_text(encoding='utf-8').strip()
    except FileNotFoundError:
        return fallback.strip()


def normalize_text(value):
    return value.replace('\r\n', '\n').replace('\r', '\n').strip()


def story_entries(root: pathlib.Path):
    if not root.exists():
        return []
    entries = []
    for path in sorted(root.glob('*.txt')):
        try:
            text = normalize_text(path.read_text(encoding='utf-8', errors='ignore'))
        except Exception:
            continue
        if not text:
            continue
        created_at = datetime.datetime.fromtimestamp(path.stat().st_mtime, datetime.timezone.utc).isoformat()
        entries.append({
            'created_at': created_at,
            'kind': 'story',
            'source': f'generated-story:{path.name}',
            'text': text,
        })
    return entries


def aware_entries(root: pathlib.Path):
    if not root.exists():
        return []
    entries = []
    for path in sorted(root.glob('*.txt')):
        try:
            raw = path.read_text(encoding='utf-8', errors='ignore')
        except Exception:
            continue
        header, _, body = raw.partition('\n\n')
        metadata = {}
        for line in header.splitlines():
            if ':' not in line:
                continue
            key, value = line.split(':', 1)
            metadata[key.strip()] = value.strip()
        kind = metadata.get('kind', '').strip().lower()
        if kind not in {'story', 'commentary'}:
            continue
        text = normalize_text(body)
        if not text:
            continue
        entries.append({
            'created_at': metadata.get('created_at') or datetime.datetime.fromtimestamp(path.stat().st_mtime, datetime.timezone.utc).isoformat(),
            'kind': kind,
            'source': f'aware-output:{path.name}',
            'text': text,
        })
    return entries


def commentary_entries(db_path: pathlib.Path):
    if not db_path.exists():
        return []
    try:
        connection = sqlite3.connect(db_path)
        connection.row_factory = sqlite3.Row
    except sqlite3.Error:
        return []
    try:
        rows = connection.execute(
            '''
            SELECT played_at, commentary_file, line_text
            FROM commentary_history
            ORDER BY played_at ASC, id ASC
            '''
        ).fetchall()
    except sqlite3.Error:
        rows = []
    finally:
        connection.close()

    entries = []
    for row in rows:
        text = normalize_text(row['line_text'] or '')
        if not text:
            continue
        source_name = pathlib.Path(row['commentary_file']).name if row['commentary_file'] else 'commentary-history'
        entries.append({
            'created_at': row['played_at'] or '',
            'kind': 'commentary',
            'source': f'commentary-history:{source_name}',
            'text': text,
        })
    return entries


generated_dir = pathlib.Path(sys.argv[1])
aware_output_dir = pathlib.Path(sys.argv[2])
commentary_db = pathlib.Path(sys.argv[3])
max_chars = max(0, int(sys.argv[4]))
max_entries = max(0, int(sys.argv[5]))
section_prompt_file = sys.argv[6]

entries = story_entries(generated_dir) + aware_entries(aware_output_dir) + commentary_entries(commentary_db)

seen_hashes = set()
deduped = []
for entry in entries:
    text_hash = hashlib.sha256(entry['text'].encode('utf-8')).hexdigest()
    if text_hash in seen_hashes:
        continue
    seen_hashes.add(text_hash)
    deduped.append(entry)

deduped.sort(key=lambda item: item['created_at'] or '', reverse=True)

selected = []
used_chars = 0
for entry in deduped:
    block = '\n'.join([
        f"[{entry['kind']}] {entry['created_at'] or 'unknown-time'} | source: {entry['source']}",
        entry['text'],
    ]).strip()
    block_len = len(block) + 2
    if selected and max_chars and used_chars + block_len > max_chars:
        continue
    selected.append((entry, block))
    used_chars += block_len
    if max_entries and len(selected) >= max_entries:
        break

if not selected:
    print('', end='')
    raise SystemExit(0)

selected.reverse()
history_text = '\n\n'.join(block for _, block in selected).strip()
template_text = load_prompt_text(
    section_prompt_file,
    '\n'.join([
        'Previous HAL stories and commentary to treat as memory:',
        'Entries included: {entry_count}',
        'Older entries omitted because of context limits: {truncated}',
        '',
        '{history_text}',
    ]),
)
payload = template_text.format_map({
    'entry_count': len(selected),
    'total_entry_count': len(deduped),
    'truncated': 'yes' if len(selected) < len(deduped) else 'no',
    'history_text': history_text,
    'memory_content': history_text,
})
print(payload.strip(), end='')
PY
}

