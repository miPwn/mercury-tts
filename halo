import datetime
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
history_limit = max(1, int(sys.argv[2]))

snapshot = {
    'timestamp': datetime.datetime.now(datetime.timezone.utc).isoformat(),
    'request_name': sys.argv[3],
    'request_class': sys.argv[4],
    'render_route': sys.argv[5],
    'playback_path': sys.argv[6],
    'cache_hit': sys.argv[7].lower() == 'true',
    'chunk_count': int(sys.argv[8]),
    'text_chars': int(sys.argv[9]),
    'client_transport_ms': int(sys.argv[10]),
    'cache_lookup_ms': int(sys.argv[11]),
    'render_request_ms': int(sys.argv[12]),
    'audio_prepare_ms': int(sys.argv[13]),
    'playback_dispatch_ms': int(sys.argv[14]),
    'total_ms': int(sys.argv[15]),
}

payload = {'latest': snapshot, 'recent': [snapshot]}
if path.exists():
    try:
        current = json.loads(path.read_text(encoding='utf-8'))
    except Exception:
        current = {}
    recent = current.get('recent', [])
    if not isinstance(recent, list):
        recent = []
    recent.append(snapshot)
    payload['recent'] = recent[-history_limit:]

path.write_text(json.dumps(payload, indent=2) + '\n', encoding='utf-8')
PY
}

show_latency_metrics() {
    local state_file

    state_file="${HALO_LATENCY_STATE_FILE:-$LATENCY_STATE_FILE_DEFAULT}"
    mkdir -p "$(dirname "$state_file")"

    if [ ! -f "$state_file" ]; then
        if [ "$LATENCY_JSON_MODE" = true ]; then
            printf '%s\n' '{"latest": null, "recent": []}'
        else
            echo 'No HAL latency data recorded yet.'
        fi
        return 0
    fi

    if [ "$LATENCY_JSON_MODE" = true ]; then
        cat "$state_file"
        return 0
    fi

    python3 - "$state_file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text(encoding='utf-8'))
latest = payload.get('latest')
recent = payload.get('recent', [])

if not latest:
    print('No HAL latency data recorded yet.')
    raise SystemExit(0)

bars = '▁▂▃▄▅▆▇█'

def sparkline(values):
    values = [max(0, int(v)) for v in values if v is not None]
    if not values:
        return ''
    peak = max(values)
    if peak <= 0:
        return bars[0] * len(values)
    return ''.join(bars[min(len(bars) - 1, round((value / peak) * (len(bars) - 1)))] for value in values)

def bar(label, value, total, width=28):
    total = max(total, 1)
    filled = min(width, round((value / total) * width))
    return f'{label:16} ' + ('█' * filled) + ('░' * (width - filled)) + f' {value:>5} ms'

print('HAL latency summary')
print(f"  Timestamp:      {latest.get('timestamp', 'unknown')}")
print(f"  Request:        {latest.get('request_name', 'unknown')} ({latest.get('request_class', 'unknown')})")
print(f"  Render route:   {latest.get('render_route', 'unknown')}")
print(f"  Playback path:  {latest.get('playback_path', 'unknown')}")
print(f"  Cache hit:      {'yes' if latest.get('cache_hit') else 'no'}")
print(f"  Chunks:         {latest.get('chunk_count', 0)}")
print(f"  Text chars:     {latest.get('text_chars', 0)}")
print('')

total = int(latest.get('total_ms', 0) or 0)
stages = [
    ('Client transport', int(latest.get('client_transport_ms', 0) or 0)),
    ('Cache lookup', int(latest.get('cache_lookup_ms', 0) or 0)),
    ('Render request', int(latest.get('render_request_ms', 0) or 0)),
    ('Audio prepare', int(latest.get('audio_prepare_ms', 0) or 0)),
    ('WAV dispatch', int(latest.get('playback_dispatch_ms', 0) or 0)),
]
for label, value in stages:
    print(bar(label, value, total))
print(bar('Total', total, total))

recent_total = [entry.get('total_ms', 0) for entry in recent[-16:]]
recent_render = [entry.get('render_request_ms', 0) for entry in recent[-16:]]
recent_playback = [entry.get('playback_dispatch_ms', 0) for entry in recent[-16:]]
print('')
print('Recent totals     ' + sparkline(recent_total))
print('Recent render     ' + sparkline(recent_render))
print('Recent WAV dispatch ' + sparkline(recent_playback))
PY
}

