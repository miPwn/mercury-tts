tts_service_available() {
    local endpoint service_root

    while IFS= read -r endpoint; do
        if [ -z "$endpoint" ]; then
            continue
        fi

        service_root="${endpoint%/api/tts}/"
        if curl -s --max-time 3 "$service_root" >/dev/null 2>&1; then
            return 0
        fi
    done < <(tts_endpoint_candidates)

    return 1
}

request_tts_audio() {
    local tmpfile="$1"
    local encoded_text="$2"
    local endpoint http_code last_error

    last_error="Error: HALO XTTS ${TTS_LABEL} request failed before attempting any endpoint"

    while IFS= read -r endpoint; do
        if [ -z "$endpoint" ]; then
            continue
        fi

        http_code=$(curl -sS --connect-timeout "$HALO_TTS_CONNECT_TIMEOUT" --max-time "$TTS_MAX_TIME" -o "$tmpfile" -w "%{http_code}" \
            "${endpoint}?text=${encoded_text}&speaker_id=${SPEAKER_ID}&language_id=${LANGUAGE}") || {
            last_error="Error: HALO XTTS ${TTS_LABEL} request failed or timed out via ${endpoint}"
            rm -f "$tmpfile"
            continue
        }

        if [ "$http_code" != "200" ]; then
            last_error="Error: HALO XTTS ${TTS_LABEL} request returned HTTP ${http_code} via ${endpoint}"
            rm -f "$tmpfile"
            continue
        fi

        TTS_ENDPOINT_USED="$endpoint"
        return 0
    done < <(tts_endpoint_candidates)

    echo "$last_error" >&2
    return 1
}

play_audio_file() {
    local audio_file="$1"
    paplay "$audio_file" 2>/dev/null || aplay "$audio_file" 2>/dev/null || {
        echo "  Error: No audio player available (tried aplay, paplay)"
        return 1
    }
}

story_playlist_is_complete() {
    local manifest_path="$1"

    if [ ! -s "$manifest_path" ]; then
        return 1
    fi

    while IFS= read -r cache_path; do
        if [ -z "$cache_path" ] || [ ! -s "$cache_path" ]; then
            return 1
        fi
    done < "$manifest_path"

    return 0
}

play_story_playlist() {
    local manifest_path="$1"
    local total_chunks current_chunk cache_path

    total_chunks=$(wc -l < "$manifest_path" | tr -d ' ')
    current_chunk=0

    while IFS= read -r cache_path; do
        if [ -z "$cache_path" ]; then
            continue
        fi
        current_chunk=$(( current_chunk + 1 ))
        if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ] && [ "$total_chunks" -gt 1 ]; then
            echo "  Playing story segment ${current_chunk}/${total_chunks}..."
        fi
        play_audio_file "$cache_path" || return 1
    done < "$manifest_path"

    return 0
}

append_trailing_silence() {
    local wav_file="$1"
    local silence_ms="$2"

    python3 - "$wav_file" "$silence_ms" <<'PY'
import pathlib
import sys
import wave

wav_path = pathlib.Path(sys.argv[1])
silence_ms = int(sys.argv[2])

if silence_ms <= 0:
    raise SystemExit(0)

with wave.open(str(wav_path), 'rb') as source:
    params = source.getparams()
    frames = source.readframes(source.getnframes())

frame_rate = params.framerate
frame_width = params.sampwidth * params.nchannels
silence_frames = max(1, int(frame_rate * silence_ms / 1000))
silence = b'\x00' * (silence_frames * frame_width)

with wave.open(str(wav_path), 'wb') as target:
    target.setparams(params)
    target.writeframes(frames)
    target.writeframes(silence)
PY
}

parse_storygen_args() {
    STORYGEN_MAX_WORDS=""
    STORYGEN_TOPIC=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -mw)
                shift
                if [ -z "${1:-}" ]; then
                    echo "Error: -mw requires a positive integer value."
                    exit 1
                fi
                if ! [[ "$1" =~ ^[0-9]+$ ]] || [ "$1" -le 0 ]; then
                    echo "Error: -mw requires a positive integer value."
                    exit 1
                fi
                STORYGEN_MAX_WORDS="$1"
                ;;
            *)
                if [ -n "$STORYGEN_TOPIC" ]; then
                    STORYGEN_TOPIC="$STORYGEN_TOPIC $1"
                else
                    STORYGEN_TOPIC="$1"
                fi
                ;;
        esac
        shift
    done
}

