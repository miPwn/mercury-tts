render_uncached_story_cache() {
    local story_file prompt_name total_count rendered_count cached_count failed_count
    total_count=0
    rendered_count=0
    cached_count=0
    failed_count=0

    prompt_name=$(basename "${HALO_STORYGEN_PROMPT_FILE:-$STORYGEN_PROMPT_FILE_DEFAULT}")
    mkdir -p "$STORY_DIR"
    storygen_status "HALO story cache sweep requested"

    while IFS= read -r -d '' story_file; do
        total_count=$(( total_count + 1 ))
        if story_file_is_cached "$story_file"; then
            cached_count=$(( cached_count + 1 ))
            storygen_status "  Cached: $(basename "$story_file")"
            continue
        fi

        storygen_status "  Rendering to cache: $(basename "$story_file")"
        if bash "$HALO_SELF" --render-only read "$story_file" >/dev/null; then
            rendered_count=$(( rendered_count + 1 ))
        else
            failed_count=$(( failed_count + 1 ))
            storygen_status "  Render failed: $(basename "$story_file")"
        fi
    done < <(find "$STORY_DIR" -maxdepth 1 -type f -name '*.txt' ! -name "$prompt_name" ! -name 'rc.txt' ! -name 'rc_*.txt' -print0 | sort -z)

    storygen_status "  Sweep summary: total=${total_count} cached=${cached_count} rendered=${rendered_count} failed=${failed_count}"
    [ "$failed_count" -eq 0 ]
}

