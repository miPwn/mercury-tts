        if [ $# -eq 0 ]; then
            usage
            exit 1
        fi
        SENSORY_ACTION="$1"
        shift
        case "$SENSORY_ACTION" in
            status)
                if [ $# -ne 0 ]; then
                    usage
                    exit 1
                fi
                ;;
            scan)
                if [ $# -gt 1 ]; then
                    usage
                    exit 1
                fi
                if [ $# -eq 1 ]; then
                    SENSORY_SENSOR="$1"
                fi
                ;;
            commentary)
                if [ $# -gt 1 ]; then
                    usage
                    exit 1
                fi
                if [ $# -eq 1 ]; then
                    SENSORY_SENSOR="$1"
                fi
                ;;
            *)
                usage
                exit 1
                ;;
        esac
        ;;
    aware)
        AWARE_COMMAND_MODE=true
        shift
        if [ $# -eq 0 ]; then
            usage
            exit 1
        fi

        AWARE_ACTION="$1"
        shift
        case "$AWARE_ACTION" in
            on|off|status|tick)
                if [ $# -ne 0 ]; then
                    usage
                    exit 1
                fi
                ;;
            trigger)
                AWARE_TRIGGER_KIND="observation"
                AWARE_TRIGGER_SOURCE="manual"
                AWARE_TRIGGER_ID="manual-cli"
                if [ $# -gt 0 ] && [[ "$1" =~ ^(commentary|observation|monologue|story)$ ]]; then
                    AWARE_TRIGGER_KIND="$1"
                    shift
                fi
                if [ $# -gt 0 ]; then
                    AWARE_TOPIC="$*"
                fi
                ;;
            *)
                usage
                exit 1
                ;;
        esac
        ;;
    read)
        READ_MODE=true
        CACHE_CATEGORY="story"
        if [ $# -ne 2 ] || [ -z "${2:-}" ]; then
            usage
            exit 1
        fi
        READ_FILE=$(resolve_story_file "$2") || {
            echo "Error: Story file not found at $2"
            exit 1
        }
        ALIAS_NAME_OVERRIDE=$(basename "$READ_FILE")
        ALIAS_NAME_OVERRIDE="${ALIAS_NAME_OVERRIDE%.*}"
        ;;
    speak)
        COMMENTARY_FILE="${HALO_COMMENTARY_FILE:-${HALO_ROOT}/commentary/manic-hal-lines.txt}"
        if [ $# -ne 1 ]; then
            usage
            exit 1
        fi
        if [ ! -f "$COMMENTARY_FILE" ]; then
            echo "Error: Commentary file not found at $COMMENTARY_FILE"
            exit 1
        fi
        if ! line=$(select_commentary_line "$COMMENTARY_FILE"); then
            echo "Error: Failed to select commentary line from $COMMENTARY_FILE"
            exit 1
        fi
        echo "Speaking commentary sample with HALO voice"
        echo "Source: $COMMENTARY_FILE"
        echo "$line"
        if [ "$RENDER_ONLY" = true ]; then
            exec env HALO_TTS_CACHE_CATEGORY=commentary bash "$HALO_SELF" --render-only "$line"
        else
            exec env HALO_TTS_CACHE_CATEGORY=commentary bash "$HALO_SELF" "$line"
        fi
        ;;
    list-stories)
        if [ $# -ne 1 ]; then
            usage
            exit 1
        fi
        LIST_STORIES_MODE=true
        ;;
    storygen|story-gen|sg)
        STORYGEN_MODE=true
        shift
        parse_storygen_args "$@"
        ;;
    *)
        if [ $# -gt 1 ]; then
            echo "Error: HALO voice supports single sentences only."
            exit 1
        fi
        SENTENCE_INPUT="$1"
        ;;
esac

if [ "$LIST_STORIES_MODE" = true ]; then
    list_stories
    exit 0
fi

if [ "$LATENCY_COMMAND_MODE" = true ]; then
    show_latency_metrics
    exit 0
fi

if [ "$AWARE_COMMAND_MODE" = true ]; then
    handle_aware_command
    exit $?
fi

if [ "$SENSORY_COMMAND_MODE" = true ]; then
    handle_sensory_command
    exit $?
fi

if [ "$STORYGEN_MODE" = true ]; then
    handle_storygen
    exit $?
fi

if ! tts_service_available; then
    echo "Error: HALO XTTS service not available via any configured endpoint"
    exit 1
fi

if [ "$READ_MODE" = true ]; then
    REQUEST_CLASS="story"
    sentence=$(python3 -c 'import pathlib, sys; print(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").replace("\r\n", "\n").replace("\r", "\n"), end="")' "$READ_FILE")
    if ! python3 -c 'import sys; raise SystemExit(0 if sys.argv[1].strip() else 1)' "$sentence"; then
        echo "Error: Story file is empty: $READ_FILE"
        exit 1
    fi
    if story_requires_chunking "$READ_FILE"; then
        render_story_in_chunks "$READ_FILE"
        exit $?
    fi
else
    sentence="$SENTENCE_INPUT"
    if [[ ! "$sentence" =~ [.!?]$ ]]; then
        sentence="${sentence}."
    fi
fi

reset_latency_metrics
set_latency_text_chars "$sentence"

mkdir -p "$CACHE_DIR"

configure_cache_paths
TTS_ENDPOINT=$(current_tts_endpoint)
TTS_MAX_TIME=$(current_tts_max_time)
TTS_LABEL=$(tts_request_label)
TTS_ENDPOINT_USED=""

if [ "$RENDER_ONLY" = true ]; then
    if [ -s "$CACHE_FILE" ]; then
        ensure_cache_mappings
        echo "$CACHE_FILE"
        exit 0
    fi
else
    if [ "${HALO_INTERNAL_READ_CHILD:-0}" = "1" ]; then
        :
    elif [ "$READ_MODE" = true ]; then
        echo "HALO reading: $READ_FILE"
    else
        echo "HALO generating: $sentence"
    fi
    if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ]; then
        echo "  Using HAL-006 cached speaker embedding (XTTS v2)..."
        echo "  Request class: $TTS_LABEL"
    fi
fi

cache_lookup_started_ms=$(now_ms)
cache_file_exists=false
if [ -s "$CACHE_FILE" ]; then
    cache_file_exists=true
fi
LATENCY_CACHE_LOOKUP_MS=$(safe_duration_ms "$cache_lookup_started_ms" "$(now_ms)")

if [ "$cache_file_exists" = true ]; then
    ensure_cache_mappings
    if [ -n "${HALO_INTERNAL_ROUTE_FILE:-}" ]; then
        printf '%s\n' 'cache' > "$HALO_INTERNAL_ROUTE_FILE"
    fi
    if [ "$RENDER_ONLY" = false ]; then
        LATENCY_CACHE_HIT="true"
        LATENCY_RENDER_ROUTE="cache"
        if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ]; then
            echo "  Cache hit: using pre-generated audio"
                echo "  Render: cache hit"
        fi
            play_audio_file "$CACHE_FILE" "$sentence" || exit 1
        persist_latency_snapshot
        if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ]; then
            echo "HALO processing complete."
        fi
    fi
    exit 0
fi

encoded_text=$(python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))' "$sentence")
TMPFILE=$(mktemp /tmp/halo_XXXXXX.wav)

render_started_ms=$(now_ms)
request_tts_audio "$TMPFILE" "$encoded_text" || {
    rm -f "$TMPFILE"
    exit 1
}
LATENCY_RENDER_REQUEST_MS=$(safe_duration_ms "$render_started_ms" "$(now_ms)")
LATENCY_RENDER_ROUTE=$(render_route_label_for_endpoint "$TTS_ENDPOINT_USED")
if [ -n "${HALO_INTERNAL_ROUTE_FILE:-}" ]; then
    printf '%s\n' "$LATENCY_RENDER_ROUTE" > "$HALO_INTERNAL_ROUTE_FILE"
fi

if [ "$RENDER_ONLY" = false ] && [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ]; then
    echo "  Render: $LATENCY_RENDER_ROUTE"
fi

audio_prepare_started_ms=$(now_ms)
FILE_TYPE=$(file -b "$TMPFILE")
if [[ ! "$FILE_TYPE" =~ WAV|RIFF|audio ]]; then
    rm -f "$TMPFILE"
    echo "Error: HALO XTTS ${TTS_LABEL} request returned unexpected file type from ${TTS_ENDPOINT_USED:-unknown endpoint}: $FILE_TYPE" >&2
    exit 1
fi

append_trailing_silence "$TMPFILE" "$HALO_TTS_TRAILING_SILENCE_MS"

if ! cp "$TMPFILE" "$CACHE_FILE"; then
    rm -f "$TMPFILE" "$CACHE_FILE"
    echo "Error: Failed to persist rendered audio to cache path $CACHE_FILE" >&2
    exit 1
fi

if [ ! -s "$CACHE_FILE" ]; then
    rm -f "$TMPFILE" "$CACHE_FILE"
    echo "Error: Cache path was written but is empty: $CACHE_FILE" >&2
    exit 1
fi

ensure_cache_mappings
rm -f "$TMPFILE"
LATENCY_AUDIO_PREP_MS=$(safe_duration_ms "$audio_prepare_started_ms" "$(now_ms)")

if [ "$RENDER_ONLY" = true ]; then
    persist_latency_snapshot
    echo "$CACHE_FILE"
    exit 0
fi

if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ]; then
    echo "  Playing HAL-006 voice..."
fi
play_audio_file "$CACHE_FILE" "$sentence" || exit 1
persist_latency_snapshot

if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ]; then
    echo "HALO processing complete."
fi
exit 0