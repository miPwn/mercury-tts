tts_endpoint_candidates() {
    local primary fallback instant_primary instant_fallback
    primary=$(current_tts_endpoint)
    fallback=$(current_tts_fallback_endpoint)
    instant_primary="$XTTS_ENDPOINT_INSTANT"
    instant_fallback="$XTTS_ENDPOINT_INSTANT_FALLBACK"

    if [ -n "$primary" ]; then
        printf '%s\n' "$primary"
    fi

    if [ -n "$fallback" ] && [ "$fallback" != "$primary" ]; then
        printf '%s\n' "$fallback"
    fi

    if [ "$REQUEST_CLASS" = "story" ]; then
        if [ -n "$instant_primary" ] && [ "$instant_primary" != "$primary" ] && [ "$instant_primary" != "$fallback" ]; then
            printf '%s\n' "$instant_primary"
        fi

        if [ -n "$instant_fallback" ] && [ "$instant_fallback" != "$primary" ] && [ "$instant_fallback" != "$fallback" ] && [ "$instant_fallback" != "$instant_primary" ]; then
            printf '%s\n' "$instant_fallback"
        fi
    fi
}

render_route_label_for_endpoint() {
    local endpoint="$1"
    local primary fallback host

    primary=$(current_tts_endpoint)
    fallback=$(current_tts_fallback_endpoint)

    if [ -n "$endpoint" ] && [ "$endpoint" = "$primary" ]; then
        printf '%s\n' "$HALO_TTS_PRIMARY_ROUTE_LABEL"
        return 0
    fi

    if [ -n "$endpoint" ] && [ "$endpoint" = "$fallback" ]; then
        printf '%s\n' "$HALO_TTS_FALLBACK_ROUTE_LABEL"
        return 0
    fi

    host=$(python3 - "$endpoint" <<'PY'
import sys
import urllib.parse

value = sys.argv[1].strip()
if not value:
    print("unknown", end="")
    raise SystemExit(0)

parsed = urllib.parse.urlparse(value)
print(parsed.hostname or value, end="")
PY
) || host="unknown"

    case "$host" in
        127.0.0.1|localhost|falcon.mipwn.local)
            printf '%s\n' 'Falcon'
            ;;
        *)
            printf '%s\n' "$host"
            ;;
    esac
}

merge_render_route_label() {
    local current="$1"
    local observed="$2"

    if [ -z "$observed" ] || [ "$observed" = "unknown" ]; then
        printf '%s\n' "$current"
        return 0
    fi

    if [ -z "$current" ] || [ "$current" = "unknown" ]; then
        printf '%s\n' "$observed"
        return 0
    fi

    if [ "$current" = "$observed" ]; then
        printf '%s\n' "$current"
        return 0
    fi

    if [ "$current" = "cache" ]; then
        printf '%s\n' "$observed"
        return 0
    fi

    if [ "$observed" = "cache" ]; then
        printf '%s\n' "$current"
        return 0
    fi

    printf '%s\n' 'mixed'
}

