current_tts_endpoint() {
    if [ "$REQUEST_CLASS" = "story" ]; then
        printf '%s\n' "$XTTS_ENDPOINT_STORY"
    else
        printf '%s\n' "$XTTS_ENDPOINT_INSTANT"
    fi
}

current_tts_fallback_endpoint() {
    if [ "$REQUEST_CLASS" = "story" ]; then
        printf '%s\n' "$XTTS_ENDPOINT_STORY_FALLBACK"
    else
        printf '%s\n' "$XTTS_ENDPOINT_INSTANT_FALLBACK"
    fi
}

tts_endpoint_candidates() {
    local primary fallback
    primary=$(current_tts_endpoint)
    fallback=$(current_tts_fallback_endpoint)

    if [ -n "$primary" ]; then
        printf '%s\n' "$primary"
    fi

    if [ -n "$fallback" ] && [ "$fallback" != "$primary" ]; then
        printf '%s\n' "$fallback"
    fi
}

current_tts_max_time() {
    if [ "$REQUEST_CLASS" = "story" ]; then
        printf '%s\n' "$HALO_TTS_MAX_TIME_STORY"
