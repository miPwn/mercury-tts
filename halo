                if [ $# -gt 1 ]; then
                    usage
                    exit 1
                fi
                if [ $# -eq 1 ]; then
                    SENSORY_SENSOR="$1"
                fi
                ;;
            *)
                usage
                exit 1
                ;;
        esac
        ;;
    aware)
        AWARE_COMMAND_MODE=true
        shift
        if [ $# -eq 0 ]; then
            usage
            exit 1
        fi

        AWARE_ACTION="$1"
        shift
        case "$AWARE_ACTION" in
