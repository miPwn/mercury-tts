story_manifest_path_for_story_file() {
    local story_file="$1"
    local story_hash

    story_hash=$(python3 - "$story_file" <<'PY'
import hashlib
import pathlib
import sys

text = pathlib.Path(sys.argv[1]).read_text(encoding='utf-8').replace('\r\n', '\n').replace('\r', '\n')
print(hashlib.sha256(text.encode('utf-8')).hexdigest())
