    text = normalize_text(path)
    if not text.strip():
        return 'EMPTY'
    if story_requires_chunking(text):
        return 'YES' if playlist_cache_exists(text) else 'NO'
    return 'YES' if single_story_cache_exists(text) else 'NO'


