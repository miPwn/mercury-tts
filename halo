play_story_playlist() {
    local manifest_path="$1"
    local total_chunks current_chunk cache_path chunk_text manifest_line

    total_chunks=$(wc -l < "$manifest_path" | tr -d ' ')
    current_chunk=0

    while IFS= read -r manifest_line; do
        cache_path=$(printf '%s\n' "$manifest_line" | cut -f1)
        chunk_text=$(printf '%s\n' "$manifest_line" | cut -f2-)
        if [ -z "$cache_path" ]; then
            continue
        fi
        current_chunk=$(( current_chunk + 1 ))
        if [ "${HALO_INTERNAL_READ_CHILD:-0}" != "1" ] && [ "$total_chunks" -gt 1 ]; then
            echo "  Playing story segment ${current_chunk}/${total_chunks}..."
        fi
        play_audio_file "$cache_path" "$chunk_text" || return 1
    done < "$manifest_path"

    return 0
}

