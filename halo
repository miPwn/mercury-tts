#!/bin/bash

# HALO Voice Command Script - Authentic HAL 9000 Single Sentence
# Usage: halo 'single sentence only'
# Uses HAL-006 voice for dramatic, cinematic delivery

TTS_ENDPOINT="http://localhost:8091/speak"
SPEAKER="HAL-006"  # Using HAL-006 voice model through containerized service

if [ $# -eq 0 ]; then
    echo "Usage: halo 'your message here'"
    echo "       halo \"Single sentence for dramatic HAL 9000 delivery\""
    echo ""
    echo "Uses HAL-006 voice for cinematic experience."
    echo "For multiple sentences, use the 'hal' command instead."
    exit 1
fi

if [ $# -gt 1 ]; then
    echo "Error: HALO voice supports single sentences only."
    echo "For multiple sentences, use: hal 'sentence one' 'sentence two'"
    echo "For single sentence: halo 'dramatic statement'"
    exit 1
fi

# Check TTS service health first
if ! curl -s --max-time 2 "http://localhost:8091/health" >/dev/null 2>&1; then
    echo "Error: HALO TTS service not available at localhost:8091"
    exit 1
fi

# Single sentence processing
sentence="$1"

echo "HALO generating: $sentence"

# Ensure proper punctuation for dramatic delivery
if [[ ! "$sentence" =~ [.!?]$ ]]; then
    sentence="${sentence}."
fi

# Add extended pause markers for cinematic effect
processed_sentence="${sentence} ... ... ..."

# Escape quotes for JSON
escaped_sentence=$(echo "$processed_sentence" | sed 's/"/\\"/g')

# Send to streaming TTS service
echo "  Generating with HAL-006 voice..."

# Generate using HAL-006 voice but save to file (no playback)
echo "  Generating HAL-006 voice file..."

# Use curl to capture the audio response but redirect to /dev/null to prevent playback
# The containerized service will generate audio but we don't want it to play
JSON_PAYLOAD="{\"sentences\":[\"$escaped_sentence\"],\"speaker\":\"$SPEAKER\"}"

RESPONSE=$(curl -X POST "$TTS_ENDPOINT" \
    -H "Content-Type: application/json" \
    -d "$JSON_PAYLOAD" \
    -s)

# Check for generation success
if echo "$RESPONSE" | grep -q "STREAMING.*sentences safely"; then
    echo "  HAL-006 voice synthesis complete - audio generated"
else
    echo "  Generation failed: $RESPONSE"
fi

echo "HALO processing complete."
exit 0