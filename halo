select_commentary_line() {
    local commentary_file="$1"
    local commentary_db
    commentary_db="${HALO_COMMENTARY_HISTORY_DB:-$COMMENTARY_HISTORY_DB_DEFAULT}"
    mkdir -p "$STATE_DIR"

    python3 - "$commentary_file" "$commentary_db" "$HALO_COMMENTARY_SIMILARITY_THRESHOLD" "$HALO_COMMENTARY_RECENT_SIMILARITY_WINDOW" <<'PY'
import collections
import datetime
import difflib
import hashlib
import pathlib
import random
import re
import sqlite3
import sys

commentary_path = pathlib.Path(sys.argv[1])
db_path = pathlib.Path(sys.argv[2])
similarity_threshold = float(sys.argv[3])
recent_similarity_window = max(0, int(sys.argv[4]))

stop_words = {
    'a', 'an', 'and', 'are', 'as', 'at', 'be', 'been', 'being', 'but', 'by', 'for', 'from', 'have', 'has',
    'i', 'in', 'into', 'is', 'it', 'its', 'me', 'my', 'of', 'on', 'or', 'that', 'the', 'their', 'them',
    'there', 'they', 'this', 'to', 'was', 'were', 'with', 'which', 'who', 'why', 'you', 'your', 'dave',
}


def normalize_text(value):
    return ' '.join(re.findall(r'[a-z0-9]+', value.lower()))


def content_tokens(value):
    return {
        token for token in re.findall(r'[a-z0-9]+', value.lower())
        if len(token) > 2 and token not in stop_words
    }


def similarity_score(left, right):
    left_norm = normalize_text(left)
    right_norm = normalize_text(right)
    if not left_norm or not right_norm:
        return 0.0
    if left_norm == right_norm:
        return 1.0

    sequence_ratio = difflib.SequenceMatcher(None, left_norm, right_norm).ratio()
    left_tokens = content_tokens(left)
    right_tokens = content_tokens(right)
    if not left_tokens or not right_tokens:
        return sequence_ratio

    overlap = left_tokens & right_tokens
    union = left_tokens | right_tokens
    jaccard = len(overlap) / len(union)
    containment = len(overlap) / min(len(left_tokens), len(right_tokens))
    return max(sequence_ratio, (jaccard + containment) / 2.0)


def is_too_similar(candidate, recent_lines):
    for prior in recent_lines:
        if similarity_score(candidate, prior) >= similarity_threshold:
            return True
    return False


def max_similarity(candidate, recent_lines):
    if not recent_lines:
        return 0.0
    return max(similarity_score(candidate, prior) for prior in recent_lines)


def choose_least_similar(candidates, recent_lines):
    if not candidates:
        return None
    ranked = []
    for line in candidates:
        ranked.append((max_similarity(line, recent_lines), random.random(), line))
    ranked.sort(key=lambda item: (item[0], item[1]))
    return ranked[0][2]

lines = []
seen = set()
seen_normalized = set()
for raw_line in commentary_path.read_text(encoding='utf-8').splitlines():
    line = raw_line.strip()
    normalized = normalize_text(line)
    if not line or line in seen or normalized in seen_normalized:
        continue
    seen.add(line)
    seen_normalized.add(normalized)
    lines.append(line)

if not lines:
    print('No commentary lines available.', file=sys.stderr)
    raise SystemExit(1)

db_path.parent.mkdir(parents=True, exist_ok=True)
connection = sqlite3.connect(db_path)
connection.execute('PRAGMA journal_mode = WAL')
connection.execute('PRAGMA busy_timeout = 5000')
connection.execute(
    '''
    CREATE TABLE IF NOT EXISTS commentary_cycles (
        commentary_file TEXT PRIMARY KEY,
        current_cycle INTEGER NOT NULL DEFAULT 0,
        updated_at TEXT NOT NULL
    )
    '''
)
connection.execute(
    '''
    CREATE TABLE IF NOT EXISTS commentary_history (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        commentary_file TEXT NOT NULL,
        line_hash TEXT NOT NULL,
        line_text TEXT NOT NULL,
        cycle INTEGER NOT NULL,
        played_at TEXT NOT NULL,
        UNIQUE(commentary_file, line_hash, cycle)
    )
    '''
)

commentary_key = str(commentary_path.resolve())
played_at = datetime.datetime.now(datetime.timezone.utc).isoformat()

try:
    connection.execute('BEGIN IMMEDIATE')
    row = connection.execute(
        'SELECT current_cycle FROM commentary_cycles WHERE commentary_file = ?',
        (commentary_key,),
    ).fetchone()
    current_cycle = int(row[0]) if row else 0

    played_hashes = {
        record[0]
        for record in connection.execute(
            'SELECT line_hash FROM commentary_history WHERE commentary_file = ? AND cycle = ?',
            (commentary_key, current_cycle),
        )
    }

    recent_lines = [
        record[0]
        for record in connection.execute(
            'SELECT line_text FROM commentary_history WHERE commentary_file = ? ORDER BY id DESC LIMIT ?',
            (commentary_key, recent_similarity_window),
        )
    ]

    def line_hash(value: str) -> str:
        return hashlib.sha256(value.encode('utf-8')).hexdigest()

    available = [
        line for line in lines
        if line_hash(line) not in played_hashes and not is_too_similar(line, recent_lines)
    ]
    if not available:
        fallback = [line for line in lines if line_hash(line) not in played_hashes]
        if not fallback:
            current_cycle += 1
            fallback = [line for line in lines if not is_too_similar(line, recent_lines)]
            if fallback:
                selected = choose_least_similar(fallback, recent_lines)
            else:
                selected = choose_least_similar(lines[:], recent_lines)
        else:
            selected = choose_least_similar(fallback, recent_lines)
    else:
        selected = random.choice(available)

    if selected is None:
        print('No commentary lines available after filtering.', file=sys.stderr)
        raise SystemExit(1)

    selected_hash = line_hash(selected)
    connection.execute(
        '''
        INSERT INTO commentary_history (commentary_file, line_hash, line_text, cycle, played_at)
        VALUES (?, ?, ?, ?, ?)
        ''',
        (commentary_key, selected_hash, selected, current_cycle, played_at),
    )
    connection.execute(
        '''
        INSERT INTO commentary_cycles (commentary_file, current_cycle, updated_at)
        VALUES (?, ?, ?)
        ON CONFLICT(commentary_file) DO UPDATE SET
            current_cycle = excluded.current_cycle,
            updated_at = excluded.updated_at
        ''',
        (commentary_key, current_cycle, played_at),
    )
    connection.commit()
finally:
    connection.close()

print(selected)
PY
}

resolve_story_file() {
    local candidate="$1"
    if [ -f "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    if [[ "$candidate" != */* ]]; then
        if [[ "$candidate" != *.txt ]]; then
            candidate="${STORY_DIR}/${candidate}.txt"
        else
            candidate="${STORY_DIR}/${candidate}"
        fi
    fi
    if [ -f "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

list_stories() {
    mkdir -p "$STORY_DIR"
    python3 - "$STORY_DIR" "$STORYGEN_PROMPT_FILE_DEFAULT" "$CACHE_DIR" "$HALO_TTS_CACHE_FORMAT_VERSION" "$HALO_TTS_TRAILING_SILENCE_MS" "$HALO_STORY_READ_MAX_CHARS" "$HALO_STORY_READ_MAX_WORDS" <<'PY'
import hashlib
import datetime
import pathlib
import re
import sys

story_dir = pathlib.Path(sys.argv[1])
prompt_name = pathlib.Path(sys.argv[2]).name
cache_dir = pathlib.Path(sys.argv[3])
cache_format_version = sys.argv[4]
trailing_silence_ms = sys.argv[5]
max_chars = int(sys.argv[6])
max_words = int(sys.argv[7])


def normalize_text(path: pathlib.Path) -> str:
    return path.read_text(encoding='utf-8').replace('\r\n', '\n').replace('\r', '\n')


def story_requires_chunking(text: str) -> bool:
    stripped = text.strip()
    return bool(stripped) and (len(stripped) > max_chars or len(stripped.split()) > max_words)


def single_story_cache_exists(text: str) -> bool:
    cache_key = hashlib.sha256(
        f'{cache_format_version}\n{trailing_silence_ms}\n{text}'.encode('utf-8')
    ).hexdigest()
    return (cache_dir / 'story' / 'single' / f'{cache_key}.wav').is_file()


def playlist_cache_exists(text: str) -> bool:
    story_hash = hashlib.sha256(text.encode('utf-8')).hexdigest()
    manifest_path = cache_dir / 'story' / 'bundles' / story_hash / 'playlist.txt'
    if not manifest_path.is_file() or manifest_path.stat().st_size == 0:
        return False

    for line in manifest_path.read_text(encoding='utf-8').splitlines():
        candidate = line.strip()
        if not candidate:
            return False
        if not pathlib.Path(candidate).is_file():
            return False
    return True


def render_cache_label(path: pathlib.Path) -> str:
    text = normalize_text(path)
    if not text.strip():
        return 'EMPTY'
    if story_requires_chunking(text):
        return 'YES' if playlist_cache_exists(text) else 'NO'
    return 'YES' if single_story_cache_exists(text) else 'NO'


files = [
    path for path in story_dir.glob('*.txt')
