story_single_cache_file_for_text() {
    local story_text="$1"
    local cache_key

    cache_key=$(printf '%s\n%s\n%s' "$HALO_TTS_CACHE_FORMAT_VERSION" "$HALO_TTS_TRAILING_SILENCE_MS" "$story_text" | sha256sum | awk '{print $1}') || return 1
    printf '%s\n' "$CACHE_DIR/story/single/${cache_key}.wav"
}

story_file_is_cached() {
    local story_file="$1"
    local story_text manifest_path single_cache_file

    story_text=$(python3 -c 'import pathlib, sys; print(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").replace("\r\n", "\n").replace("\r", "\n"), end="")' "$story_file") || return 1
    if ! python3 -c 'import sys; raise SystemExit(0 if sys.argv[1].strip() else 1)' "$story_text"; then
        return 1
    fi

    if story_requires_chunking "$story_file"; then
        manifest_path=$(story_manifest_path_for_story_file "$story_file") || return 1
        story_playlist_is_complete "$manifest_path"
        return $?
    fi

    single_cache_file=$(story_single_cache_file_for_text "$story_text") || return 1
    [ -s "$single_cache_file" ]
}

render_uncached_story_cache() {
    local story_file prompt_name total_count rendered_count cached_count failed_count
    total_count=0
    rendered_count=0
    cached_count=0
    failed_count=0

    prompt_name=$(basename "${HALO_STORYGEN_PROMPT_FILE:-$STORYGEN_PROMPT_FILE_DEFAULT}")
    mkdir -p "$STORY_DIR"
    storygen_status "HALO story cache sweep requested"

    while IFS= read -r -d '' story_file; do
        total_count=$(( total_count + 1 ))
        if story_file_is_cached "$story_file"; then
            cached_count=$(( cached_count + 1 ))
            storygen_status "  Cached: $(basename "$story_file")"
            continue
        fi

        storygen_status "  Rendering to cache: $(basename "$story_file")"
        if bash "$HALO_SELF" --render-only read "$story_file" >/dev/null; then
            rendered_count=$(( rendered_count + 1 ))
        else
            failed_count=$(( failed_count + 1 ))
            storygen_status "  Render failed: $(basename "$story_file")"
        fi
    done < <(find "$STORY_DIR" -maxdepth 1 -type f -name '*.txt' ! -name "$prompt_name" -print0 | sort -z)

    storygen_status "  Sweep summary: total=${total_count} cached=${cached_count} rendered=${rendered_count} failed=${failed_count}"
    [ "$failed_count" -eq 0 ]
}

