split_story_into_chunks() {
    local story_file="$1"
    local chunk_dir="$2"
    python3 - "$story_file" "$chunk_dir" "$HALO_STORY_READ_MAX_CHARS" "$HALO_STORY_READ_MAX_WORDS" <<'PY'
import pathlib
import re
import sys

story_file = pathlib.Path(sys.argv[1])
chunk_dir = pathlib.Path(sys.argv[2])
max_chars = int(sys.argv[3])
max_words = int(sys.argv[4])

text = story_file.read_text(encoding='utf-8').replace('\r\n', '\n').replace('\r', '\n').strip()
if not text:
    raise SystemExit(1)

chunk_dir.mkdir(parents=True, exist_ok=True)

paragraphs = [paragraph.strip() for paragraph in re.split(r'\n\s*\n+', text) if paragraph.strip()]
chunks = []

def flush(buffer):
    joined = ' '.join(part.strip() for part in buffer if part.strip()).strip()
    if joined:
        chunks.append(joined)

def split_oversized_sentence(sentence):
    sentence = re.sub(r'\s+', ' ', sentence).strip()
    if not sentence:
        return []
    if len(sentence) <= max_chars and len(sentence.split()) <= max_words:
        return [sentence]

    clauses = [part.strip() for part in re.split(r'(?<=[,;:])\s+', sentence) if part.strip()]
    if len(clauses) > 1:
        parts = []
        buffer = []
        buffer_words = 0
        for clause in clauses:
            clause_words = len(clause.split())
            candidate = ' '.join(buffer + [clause]).strip()
            if buffer and (len(candidate) > max_chars or (buffer_words + clause_words) > max_words):
                parts.extend(split_oversized_sentence(' '.join(buffer)))
                buffer = [clause]
                buffer_words = clause_words
                continue
            buffer.append(clause)
            buffer_words += clause_words
        if buffer:
            parts.extend(split_oversized_sentence(' '.join(buffer)))
        return parts

    words = sentence.split()
    parts = []
    current = []
    current_len = 0
    for word in words:
        separator = 1 if current else 0
        candidate_len = current_len + separator + len(word)
        if current and (len(current) >= max_words or candidate_len > max_chars):
            parts.append(' '.join(current))
            current = [word]
            current_len = len(word)
            continue
        current.append(word)
        current_len = candidate_len
    if current:
        parts.append(' '.join(current))
    return [part.strip() for part in parts if part.strip()]

for paragraph in paragraphs:
    paragraph = re.sub(r'\s+', ' ', paragraph).strip()
    if not paragraph:
        continue

    sentences = [part.strip() for part in re.split(r'(?<=[.!?])\s+', paragraph) if part.strip()]
    if not sentences:
        sentences = [paragraph]

    expanded_sentences = []
    for sentence in sentences:
        expanded_sentences.extend(split_oversized_sentence(sentence))
    if not expanded_sentences:
        expanded_sentences = [paragraph]

    buffer = []
    current_words = 0

    for sentence in expanded_sentences:
        sentence_words = len(sentence.split())
        candidate = ' '.join(buffer + [sentence]).strip()
        if buffer and (len(candidate) > max_chars or (current_words + sentence_words) > max_words):
            flush(buffer)
            buffer = [sentence]
            current_words = sentence_words
            continue
        buffer.append(sentence)
        current_words += sentence_words

    flush(buffer)

if not chunks:
    chunks = [text]

for index, chunk in enumerate(chunks, start=1):
    (chunk_dir / f'chunk-{index:04d}.txt').write_text(chunk + '\n', encoding='utf-8')

print(len(chunks))
PY
}

render_story_in_chunks() {
    local story_file="$1"
    local story_hash chunk_dir manifest_path manifest_tmp chunk_file chunk_text cache_path chunk_count

    story_hash=$(python3 - "$story_file" <<'PY'
import hashlib
import pathlib
import sys

text = pathlib.Path(sys.argv[1]).read_text(encoding='utf-8').replace('\r\n', '\n').replace('\r', '\n')
print(hashlib.sha256(text.encode('utf-8')).hexdigest())
PY
) || return 1

    chunk_dir=$(mktemp -d "${STATE_DIR}/story-read.XXXXXX") || return 1
    manifest_path="${CACHE_DIR}/${story_hash}.playlist.txt"
    manifest_tmp="${manifest_path}.tmp"

    if story_playlist_is_complete "$manifest_path"; then
        if [ "$RENDER_ONLY" = true ]; then
            printf '%s\n' "$manifest_path"
        else
            echo "HALO reading: $story_file"
            echo "  Story playlist cache hit"
            play_story_playlist "$manifest_path" || return 1
            echo "HALO processing complete."
        fi
        return 0
    fi

    if ! chunk_count=$(split_story_into_chunks "$story_file" "$chunk_dir"); then
        rm -rf "$chunk_dir"
        return 1
    fi

    if [ "$chunk_count" -le 0 ]; then
        rm -rf "$chunk_dir"
        return 1
    fi

    : > "$manifest_tmp"

    if [ "$RENDER_ONLY" = false ]; then
        echo "HALO reading: $story_file"
        echo "  Chunking story into ${chunk_count} segments for XTTS..."
    fi

    while IFS= read -r -d '' chunk_file; do
        chunk_text=$(python3 -c 'import pathlib, sys; print(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").strip(), end="")' "$chunk_file")
        if [ -z "$chunk_text" ]; then
            continue
        fi

        cache_path=$(HALO_INTERNAL_READ_CHILD=1 HALO_TTS_REQUEST_CLASS=story "$0" --render-only "$chunk_text") || {
            rm -f "$manifest_tmp"
            rm -rf "$chunk_dir"
            return 1
        }
        printf '%s\n' "$cache_path" >> "$manifest_tmp"

        if [ "$RENDER_ONLY" = false ]; then
            play_audio_file "$cache_path" || {
                rm -f "$manifest_tmp"
                rm -rf "$chunk_dir"
                return 1
            }
        fi
    done < <(find "$chunk_dir" -maxdepth 1 -type f -name 'chunk-*.txt' -print0 | sort -z)

    rm -rf "$chunk_dir"

    mv "$manifest_tmp" "$manifest_path"

    if [ "$RENDER_ONLY" = true ]; then
        printf '%s\n' "$manifest_path"
    else
        echo "HALO processing complete."
    fi
}

generate_request_id() {
    printf '%s-%s-%s\n' "$(date -u +%Y%m%d-%H%M%S)" "$$" "$(python3 -c 'import uuid; print(uuid.uuid4().hex[:8])')"
}

request_state_dir() {
    local request_id="$1"
    local directory
    for directory in "$QUEUE_PENDING_DIR" "$QUEUE_PROCESSING_DIR" "$QUEUE_DONE_DIR" "$QUEUE_FAILED_DIR"; do
        if [ -d "$directory/$request_id" ]; then
            printf '%s\n' "$directory/$request_id"
            return 0
        fi
    done
    return 1
}

acquire_queue_lock() {
    local wait_seconds="${1:-0}"
    local start_time current_time lock_pid lock_age
    start_time=$(date +%s)
    while true; do
        if mkdir "$QUEUE_LOCK_DIR" 2>/dev/null; then
            printf '%s\n' "$$" > "$QUEUE_LOCK_DIR/pid"
            return 0
        fi

        lock_pid=""
        if [ -f "$QUEUE_LOCK_DIR/pid" ]; then
            lock_pid=$(tr -d '\r\n' < "$QUEUE_LOCK_DIR/pid" 2>/dev/null)
        fi
        lock_age=$(( $(date +%s) - $(stat -c %Y "$QUEUE_LOCK_DIR" 2>/dev/null || echo 0) ))
        if [ -z "$lock_pid" ] || ! kill -0 "$lock_pid" 2>/dev/null || [ "$lock_age" -gt 1800 ]; then
            rm -rf "$QUEUE_LOCK_DIR"
            continue
        fi

        current_time=$(date +%s)
        if [ $(( current_time - start_time )) -ge "$wait_seconds" ]; then
            return 1
        fi
        sleep 1
    done
}

release_queue_lock() {
    if [ -d "$QUEUE_LOCK_DIR" ] && [ -f "$QUEUE_LOCK_DIR/pid" ]; then
        if [ "$(tr -d '\r\n' < "$QUEUE_LOCK_DIR/pid" 2>/dev/null)" = "$$" ]; then
            rm -rf "$QUEUE_LOCK_DIR"
        fi
    fi
}

enqueue_storygen_request() {
    local topic="$1"
    local max_words="$2"
    local request_id request_dir
    ensure_storygen_dirs
    request_id=$(generate_request_id)
    request_dir="$QUEUE_PENDING_DIR/$request_id"
    mkdir -p "$request_dir"
    printf '%s' "$topic" > "$request_dir/topic.txt"
    if [ -n "$max_words" ]; then
        printf '%s\n' "$max_words" > "$request_dir/max_words.txt"
    fi
    printf '%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$request_dir/created_at.txt"
    printf '%s\n' "$OPENAI_MODEL" > "$request_dir/model.txt"
    printf '%s\n' "$request_id"
}

generate_story_text() {
    local topic="$1"
    local max_words="$2"
    local prompt_text user_prompt

    prompt_text=$(resolve_storygen_prompt)
    if [ -n "$topic" ]; then
        user_prompt="Generate one new story. Topic or seed: ${topic}"
    else
        user_prompt="Generate one new story with no further constraints beyond the system prompt."
    fi
    if [ -n "$max_words" ]; then
        user_prompt="${user_prompt} Maximum words: ${max_words}. This limit is mandatory."
    fi
    generate_openai_text "$prompt_text" "$user_prompt" 180
}

build_story_filename() {
    local topic="$1"
    local story_tmp="$2"
    python3 - "$topic" "$story_tmp" <<'PY'
import pathlib
import re
import sys
import unicodedata

topic = sys.argv[1].strip()
story_text = pathlib.Path(sys.argv[2]).read_text(encoding='utf-8').strip()
seed = topic or story_text.splitlines()[0] if story_text else 'story'
seed = unicodedata.normalize('NFKD', seed)
seed = seed.encode('ascii', 'ignore').decode('ascii')
words = re.findall(r'[A-Za-z0-9]+', seed.lower())
stop_words = {
    'a', 'an', 'and', 'are', 'as', 'at', 'be', 'but', 'by', 'do', 'for', 'from', 'have',
    'i', 'in', 'is', 'it', 'its', 'me', 'my', 'of', 'on', 'or', 'that', 'the', 'their',
    'them', 'there', 'they', 'this', 'to', 'was', 'we', 'with', 'you', 'your'
}

preferred = [word for word in words if word not in stop_words]
selected = preferred[:3]
if len(selected) < 2:
    selected = words[:3]
slug = '-'.join(selected[:3]) or 'story'
print(f'{slug[:48]}.txt')
PY
}

store_story_file() {
    local topic="$1"
    local story_tmp="$2"
    local filename target

    filename=$(build_story_filename "$topic" "$story_tmp")
    target="$STORY_DIR/$filename"
    if [ -e "$target" ]; then
        target="${target%.txt}__$(date -u +%s).txt"
    fi
    mv "$story_tmp" "$target"
    printf '%s\n' "$target"
}

mark_request_failed() {
    local request_dir="$1"
    local destination="$QUEUE_FAILED_DIR/$(basename "$request_dir")"
    mkdir -p "$destination"
    cp -a "$request_dir/." "$destination/" 2>/dev/null || true
    rm -rf "$request_dir"
}

mark_request_done() {
    local request_dir="$1"
    local destination="$QUEUE_DONE_DIR/$(basename "$request_dir")"
    mkdir -p "$destination"
    cp -a "$request_dir/." "$destination/" 2>/dev/null || true
    rm -rf "$request_dir"
}

process_story_request() {
    local request_dir="$1"
    local topic max_words story_tmp story_path cache_file_path

    topic=""
    max_words=""
    if [ -f "$request_dir/topic.txt" ]; then
        topic=$(cat "$request_dir/topic.txt")
    fi
    if [ -f "$request_dir/max_words.txt" ]; then
        max_words=$(tr -d '\r\n' < "$request_dir/max_words.txt")
    fi
    printf '%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$request_dir/started_at.txt"

    story_tmp=$(mktemp "$request_dir/story.XXXXXX.txt") || return 1
    if ! generate_story_text "$topic" "$max_words" > "$story_tmp" 2> "$request_dir/error.log"; then
        rm -f "$story_tmp"
        printf '%s\n' "generation_failed" > "$request_dir/status.txt"
        mark_request_failed "$request_dir"
        return 1
    fi

    if [ -n "$max_words" ]; then
        python3 - "$story_tmp" "$max_words" <<'PY'
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
max_words = int(sys.argv[2])
text = path.read_text(encoding='utf-8')
tokens = list(re.finditer(r'\S+', text))
if len(tokens) > max_words:
    cutoff = tokens[max_words - 1].end()
    text = text[:cutoff].rstrip()
    path.write_text(text + '\n', encoding='utf-8')
PY
    fi

    if ! python3 - "$story_tmp" <<'PY'
import pathlib
import sys

text = pathlib.Path(sys.argv[1]).read_text(encoding='utf-8')
raise SystemExit(0 if text.strip() else 1)
PY
    then
        rm -f "$story_tmp"
        printf '%s\n' "empty_story" > "$request_dir/status.txt"
        printf '%s\n' "OpenAI returned an empty story." > "$request_dir/error.log"
        mark_request_failed "$request_dir"
        return 1
    fi

    story_path=$(store_story_file "$topic" "$story_tmp") || {
        rm -f "$story_tmp"
        printf '%s\n' "store_failed" > "$request_dir/status.txt"
        mark_request_failed "$request_dir"
        return 1
    }

    if ! cache_file_path=$("$0" --render-only read "$story_path" 2> "$request_dir/render_error.log"); then
        printf '%s\n' "$story_path" > "$request_dir/result_path.txt"
        printf '%s\n' "$(basename "$story_path")" > "$request_dir/result_name.txt"
        printf '%s\n' "render_failed" > "$request_dir/status.txt"
        if [ -s "$request_dir/render_error.log" ]; then
            cp "$request_dir/render_error.log" "$request_dir/error.log" 2>/dev/null || cat "$request_dir/render_error.log" > "$request_dir/error.log"
        else
            printf '%s\n' "Error: story audio render failed for $(basename "$story_path")" > "$request_dir/error.log"
        fi
        mark_request_failed "$request_dir"
        return 1
    fi

    rm -f "$request_dir/render_error.log"

    printf '%s\n' "$story_path" > "$request_dir/result_path.txt"
    printf '%s\n' "$(basename "$story_path")" > "$request_dir/result_name.txt"
    printf '%s\n' "$cache_file_path" > "$request_dir/result_audio_path.txt"
    printf '%s\n' "done" > "$request_dir/status.txt"
    printf '%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$request_dir/finished_at.txt"
    mark_request_done "$request_dir"
    return 0
}

process_storygen_queue() {
    local request_dir processing_dir

    ensure_storygen_dirs
    if ! acquire_queue_lock 0; then
        return 0
    fi

    while true; do
        request_dir=$(find "$QUEUE_PENDING_DIR" -mindepth 1 -maxdepth 1 -type d | sort | head -n 1)
        if [ -z "$request_dir" ]; then
            break
        fi

        processing_dir="$QUEUE_PROCESSING_DIR/$(basename "$request_dir")"
        if ! mv "$request_dir" "$processing_dir" 2>/dev/null; then
            continue
        fi
        process_story_request "$processing_dir" || true
    done

    release_queue_lock
}

wait_for_story_request() {
    local request_id="$1"
    local deadline request_dir state_label last_state last_notice_at now
    deadline=$(( $(date +%s) + HALO_STORYGEN_WAIT_SECONDS ))
    last_state=""
    last_notice_at=0

    while [ "$(date +%s)" -le "$deadline" ]; do
        if request_dir=$(request_state_dir "$request_id"); then
            case "$request_dir" in
                "$QUEUE_PENDING_DIR"/*)
                    state_label="queued"
                    ;;
                "$QUEUE_PROCESSING_DIR"/*)
                    state_label="generating"
                    ;;
                "$QUEUE_DONE_DIR"/*)
                    state_label="done"
                    ;;
                "$QUEUE_FAILED_DIR"/*)
                    state_label="failed"
                    ;;
                *)
                    state_label="unknown"
                    ;;
            esac

            if [ "$state_label" != "$last_state" ]; then
                case "$state_label" in
                    queued)
                        storygen_status "  Queue status: queued"
                        ;;
                    generating)
                        storygen_status "  Queue status: generating story text and audio"
                        ;;
                    done)
                        storygen_status "  Queue status: complete"
                        ;;
                    failed)
                        storygen_status "  Queue status: failed"
                        ;;
                esac
                last_state="$state_label"
                last_notice_at=$(date +%s)
            fi

            case "$request_dir" in
                "$QUEUE_DONE_DIR"/*)
                    cat "$request_dir/result_path.txt"
                    return 0
                    ;;
                "$QUEUE_FAILED_DIR"/*)
                    if [ -f "$request_dir/error.log" ]; then
                        cat "$request_dir/error.log" >&2
                    elif [ -f "$request_dir/render_error.log" ]; then
                        cat "$request_dir/render_error.log" >&2
                    else
                        echo "Error: story generation failed for request $request_id" >&2
                    fi
                    return 1
                    ;;
            esac
        fi
        now=$(date +%s)
        if [ $(( now - last_notice_at )) -ge 10 ]; then
            storygen_status "  Waiting for request $request_id..."
            last_notice_at=$now
        fi
        process_storygen_queue || true
        sleep 1
    done

    echo "Error: timed out waiting for story generation request $request_id" >&2
    return 1
}

handle_storygen() {
    local request_id story_path
    load_storygen_env
    storygen_status "HALO story generation requested"
    if [ -n "$STORYGEN_TOPIC" ]; then
        storygen_status "  Topic: $STORYGEN_TOPIC"
    else
        storygen_status "  Topic: random"
    fi
    if [ -n "$STORYGEN_MAX_WORDS" ]; then
        storygen_status "  Max words: $STORYGEN_MAX_WORDS"
    fi
    request_id=$(enqueue_storygen_request "$STORYGEN_TOPIC" "$STORYGEN_MAX_WORDS")
    storygen_status "  Request id: $request_id"
    process_storygen_queue || true
    story_path=$(wait_for_story_request "$request_id") || return 1
    if [ "$RENDER_ONLY" = true ]; then
        printf '%s\n' "$story_path"
    else
        echo "HALO story ready: $story_path"
    fi
}

