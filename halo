select_aware_memory_context() {
    local kind="$1"
    local topic="$2"
    local trigger_source="$3"
    local memory_db summary_file
    memory_db="${HALO_AWARE_MEMORY_DB:-$AWARE_MEMORY_DB_DEFAULT}"
    summary_file="${HALO_AWARE_SUMMARY_FILE:-$AWARE_SUMMARY_FILE_DEFAULT}"
    ensure_aware_dirs

    python3 - "$memory_db" "$summary_file" "$kind" "$topic" "$trigger_source" "$HALO_AWARE_RECENT_HISTORY_LIMIT" "$HALO_AWARE_RELEVANT_HISTORY_LIMIT" <<'PY'
import json
import pathlib
import re
import sqlite3
import sys

memory_db = pathlib.Path(sys.argv[1])
summary_file = pathlib.Path(sys.argv[2])
kind = sys.argv[3]
topic = sys.argv[4]
trigger_source = sys.argv[5]
recent_limit = int(sys.argv[6])
relevant_limit = int(sys.argv[7])

payload = {
    'summary': '',
    'recent': [],
    'relevant': [],
    'query': {
        'kind': kind,
        'topic': topic,
        'trigger_source': trigger_source,
    },
}

if summary_file.exists():
    payload['summary'] = summary_file.read_text(encoding='utf-8').strip()

if not memory_db.exists():
    print(json.dumps(payload))
    raise SystemExit(0)

connection = sqlite3.connect(memory_db)
connection.row_factory = sqlite3.Row

try:
    rows = connection.execute(
        '''
        SELECT created_at, kind, trigger_source, topic, text, summary_snippet, artifact_path
        FROM aware_outputs
        ORDER BY created_at DESC
        LIMIT 48
        '''
    ).fetchall()
except sqlite3.Error:
    rows = []
finally:
    connection.close()

def tokenize(value):
    return set(re.findall(r'[a-z0-9]+', (value or '').lower()))

query_tokens = tokenize(topic)
query_tokens.update(tokenize(kind))
query_tokens.update(tokenize(trigger_source))

entries = []
for row in rows:
    item = {
        'created_at': row['created_at'],
        'kind': row['kind'],
        'trigger_source': row['trigger_source'],
        'topic': row['topic'] or '',
        'summary_snippet': row['summary_snippet'],
        'artifact_path': row['artifact_path'] or '',
        'text_excerpt': (row['text'] or '').strip()[:700],
    }
    entries.append(item)

payload['recent'] = entries[:recent_limit]
recent_keys = {(entry['created_at'], entry['summary_snippet']) for entry in payload['recent']}

scored = []
for index, entry in enumerate(entries[recent_limit:], start=recent_limit):
    text_tokens = tokenize(entry['topic']) | tokenize(entry['summary_snippet']) | tokenize(entry['text_excerpt'])
    overlap = len(query_tokens & text_tokens)
    recency_bonus = max(0, 12 - index)
    score = overlap * 10 + recency_bonus
    scored.append((score, index, entry))

scored.sort(key=lambda item: (-item[0], item[1]))
payload['relevant'] = [
    entry for score, _, entry in scored
    if score > 0 and (entry['created_at'], entry['summary_snippet']) not in recent_keys
][:relevant_limit]

print(json.dumps(payload))
PY
}

