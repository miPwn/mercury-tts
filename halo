import sqlite3
import sys

memory_db = pathlib.Path(sys.argv[1])
summary_file = pathlib.Path(sys.argv[2])
entry_limit = int(sys.argv[3])
max_chars = int(sys.argv[4])

if not memory_db.exists():
    summary_file.write_text('No HAL aware outputs have been recorded yet.\n', encoding='utf-8')
    raise SystemExit(0)

connection = sqlite3.connect(memory_db)
connection.row_factory = sqlite3.Row

try:
    rows = connection.execute(
        '''
        SELECT created_at, kind, trigger_source, topic, summary_snippet
        FROM aware_outputs
        ORDER BY created_at DESC
        LIMIT ?
        ''',
        (entry_limit,),
    ).fetchall()
except sqlite3.Error:
    rows = []
finally:
    connection.close()

lines = [
    'HAL aware continuity digest',
    'Use this as compressed memory, not as an exhaustive transcript.',
    '',
]

for row in rows:
    topic_suffix = f' | topic: {row["topic"]}' if row['topic'] else ''
    lines.append(f'- {row["created_at"]} | {row["kind"]} | trigger: {row["trigger_source"]}{topic_suffix}')
    lines.append(f'  {row["summary_snippet"]}')

text = '\n'.join(lines).strip() + '\n'
if len(text) > max_chars:
    text = text[:max_chars].rstrip() + '\n'

summary_file.write_text(text, encoding='utf-8')
PY
}

