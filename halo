append_trailing_silence() {
    local wav_file="$1"
    local silence_ms="$2"
    local fade_ms="${3:-0}"

    python3 - "$wav_file" "$silence_ms" "$fade_ms" <<'PY'
import pathlib
import struct
import sys
import wave

wav_path = pathlib.Path(sys.argv[1])
silence_ms = int(sys.argv[2])
fade_ms = int(sys.argv[3])

if silence_ms <= 0 and fade_ms <= 0:
    raise SystemExit(0)

with wave.open(str(wav_path), 'rb') as source:
    params = source.getparams()
    frames = source.readframes(source.getnframes())

frame_rate = params.framerate
channels = params.nchannels
sample_width = params.sampwidth
frame_width = sample_width * channels


def apply_tail_fade(raw_frames: bytes) -> bytes:
    if fade_ms <= 0 or not raw_frames:
        return raw_frames

    format_map = {
        1: ('B', 0, 255, 128),
        2: ('h', -32768, 32767, 0),
        4: ('i', -2147483648, 2147483647, 0),
    }
    format_info = format_map.get(sample_width)
    if format_info is None:
        return raw_frames

    sample_format, sample_min, sample_max, bias = format_info
    total_frames = len(raw_frames) // frame_width
    fade_frames = min(total_frames, max(1, int(frame_rate * fade_ms / 1000)))
    if fade_frames <= 0:
        return raw_frames

    total_samples = total_frames * channels
    unpack_format = '<' + (sample_format * total_samples)
    samples = list(struct.unpack(unpack_format, raw_frames))
    start_frame = total_frames - fade_frames

    for frame_index in range(start_frame, total_frames):
        remaining = total_frames - frame_index - 1
        scale = remaining / fade_frames
        for channel_index in range(channels):
            sample_index = frame_index * channels + channel_index
            sample_value = samples[sample_index]
            if bias:
                centered = sample_value - bias
                faded = int(round(centered * scale)) + bias
                samples[sample_index] = max(sample_min, min(sample_max, faded))
            else:
                faded = int(round(sample_value * scale))
                samples[sample_index] = max(sample_min, min(sample_max, faded))

    return struct.pack(unpack_format, *samples)

frames = apply_tail_fade(frames)

silence = b''
if silence_ms > 0:
    silence_frames = max(1, int(frame_rate * silence_ms / 1000))
    silence = b'\x00' * (silence_frames * frame_width)

with wave.open(str(wav_path), 'wb') as target:
    target.setparams(params)
    target.writeframes(frames)
    target.writeframes(silence)
PY
}

parse_storygen_args() {
    STORYGEN_RENDER_CACHE_MODE=false
    STORYGEN_MAX_WORDS=""
    STORYGEN_TOPIC=""
    STORYGEN_FORMAT="story"
    STORYGEN_PODCAST_MINUTES=""

    podcast_minutes_to_words() {
        local minutes="$1"
        printf '%s\n' "$(( (minutes * 1000 + 8) / 9 ))"
    }

    while [ $# -gt 0 ]; do
        case "$1" in
            -rc)
                STORYGEN_RENDER_CACHE_MODE=true
                ;;
            -mw)
                shift
                if [ -z "${1:-}" ]; then
                    echo "Error: -mw requires a positive integer value."
                    exit 1
                fi
                if ! [[ "$1" =~ ^[0-9]+$ ]] || [ "$1" -le 0 ]; then
                    echo "Error: -mw requires a positive integer value."
                    exit 1
                fi
                STORYGEN_MAX_WORDS="$1"
                ;;
            -pc)
                shift
                if [ -z "${1:-}" ]; then
                    echo "Error: -pc requires a positive integer minute value."
                    exit 1
                fi
                if ! [[ "$1" =~ ^[0-9]+$ ]] || [ "$1" -le 0 ]; then
                    echo "Error: -pc requires a positive integer minute value."
                    exit 1
                fi
                STORYGEN_FORMAT="podcast"
                STORYGEN_PODCAST_MINUTES="$1"
                ;;
            *)
                if [ -n "$STORYGEN_TOPIC" ]; then
                    STORYGEN_TOPIC="$STORYGEN_TOPIC $1"
                else
                    STORYGEN_TOPIC="$1"
                fi
                ;;
        esac
        shift
    done

    if [ -n "$STORYGEN_PODCAST_MINUTES" ] && [ -n "$STORYGEN_MAX_WORDS" ]; then
        echo "Error: -pc cannot be combined with -mw." >&2
        exit 1
    fi

    if [ -n "$STORYGEN_PODCAST_MINUTES" ]; then
        STORYGEN_MAX_WORDS=$(podcast_minutes_to_words "$STORYGEN_PODCAST_MINUTES")
    fi

    if [ "$STORYGEN_RENDER_CACHE_MODE" = true ] && { [ -n "$STORYGEN_MAX_WORDS" ] || [ -n "$STORYGEN_TOPIC" ]; }; then
        echo "Error: -rc cannot be combined with -mw, -pc, or a story topic." >&2
        exit 1
    fi
}

