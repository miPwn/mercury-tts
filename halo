def single_story_cache_exists(text: str) -> bool:
    cache_key = hashlib.sha256(
        f'{cache_format_version}\n{tail_fade_ms}\n{trailing_silence_ms}\n{text}'.encode('utf-8')
    ).hexdigest()
    index_path = cache_dir / 'story' / 'single' / 'index' / f'{cache_key}.json'
