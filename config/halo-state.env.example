# Primary state backend.
HALO_STATE_BACKEND=postgres

# Postgres should remain the system of record for identity, memory, sensory state,
# document ingestion metadata, generated artifacts, and retrieval telemetry.
HALO_STATE_POSTGRES_DSN=postgresql://halo_state:change-me@localhost:5432/halo_state
HALO_STATE_POSTGRES_SCHEMA=halo
HALO_STATE_PROFILE_KEY=hal-9000

# Qdrant is used for semantic retrieval over imported documents and selected
# memory summaries. Canonical metadata stays in Postgres.
HALO_STATE_QDRANT_URL=https://your-qdrant-endpoint
HALO_STATE_QDRANT_API_KEY=
HALO_STATE_QDRANT_COLLECTION=halo-memory

# Learning material ingestion root.
HALO_STATE_DOCUMENT_ROOT=Z:/hal-system-monitor/learning_matrial
HALO_STATE_DOCUMENT_GLOB=**/*

# Embeddings and retrieval defaults.
HALO_STATE_EMBEDDING_MODEL=text-embedding-3-small
HALO_STATE_EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
HALO_STATE_RETRIEVAL_TOP_K=8
HALO_STATE_MEMORY_TOP_K=6
HALO_STATE_CANON_TOP_K=4

# Cutover flags for migration from the current SQLite and file-backed state.
HALO_STATE_ENABLE_DUAL_WRITE=0
HALO_STATE_ENABLE_VECTOR_INDEX=1
HALO_STATE_ENABLE_LEARNING_INGEST=1