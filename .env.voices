# TTS Voice Configuration
# Default voice for HAL persona
HAL_VOICE_TYPE=cloned
HAL_CLONED_VOICE=hal_006
HAL_CLONED_SERVER=http://localhost:5003

# Fallback VCTK voice (production TTS)
HAL_VCTK_VOICE=p254
HAL_VCTK_SERVER=http://your-tts-server:5002

# Voice switching mode
# Options: cloned, vctk, auto
VOICE_MODE=cloned

# Voice quality settings
VOICE_LANGUAGE=en
VOICE_SPEED=1.0