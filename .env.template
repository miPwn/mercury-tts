# TTS Pipeline Environment Configuration Template
# Copy to .env and customize for your environment

# Coqui TTS Backend Configuration
TTS_LOADBALANCER_URL=http://your-tts-server:5002/api/tts
TTS_DIRECT_URL=http://your-tts-direct:5002/api/tts
TTS_HEALTH_ENDPOINT=http://your-tts-server:5002/health

# Daemon Configuration
DAEMON_PORT=8091
DAEMON_HOST=localhost
DAEMON_READ_TIMEOUT=2s
DAEMON_WRITE_TIMEOUT=3s
DAEMON_IDLE_TIMEOUT=60s

# Audio Configuration
DEFAULT_SPEAKER=p245
HAL_SPEAKER=p254
DRAG_THRESHOLD_SECONDS=3
MAX_RETRIES=2
WARMUP_CONNECTION_COUNT=5

# Performance Tuning
HTTP_TIMEOUT_SECONDS=30
HTTP_RESPONSE_HEADER_TIMEOUT_SECONDS=10
MAX_IDLE_CONNECTIONS=100
MAX_IDLE_CONNECTIONS_PER_HOST=20
IDLE_CONNECTION_TIMEOUT_SECONDS=300

# File System Configuration
TMP_AUDIO_DIR=/tmp/tts_pipeline_cache
LOG_LEVEL=INFO
LOG_FILE=/var/log/tts_pipeline.log

# Development/Testing
ENABLE_PERFORMANCE_METRICS=true
ENABLE_DEBUG_LOGGING=false
MOCK_TTS_SERVER=false

# Security (if needed in future)
# TTS_API_KEY=
# TTS_AUTH_TOKEN=
# ADMIN_PASSWORD=

# Kubernetes Configuration (if applicable)
TTS_NAMESPACE=tts
TTS_DEPLOYMENT_NAME=coqui-tts
KUBECTL_CONTEXT=default