# Mercury TTS environment template

# Backend selection
TTS_LOADBALANCER_URL=http://your-tts-server:5002/api/tts
TTS_DIRECT_URL=http://your-tts-direct:5002/api/tts
TTS_HEALTH_ENDPOINT=/health

# Daemon service
DAEMON_HOST=0.0.0.0
DAEMON_PORT=8091
DAEMON_READ_TIMEOUT=2s
DAEMON_WRITE_TIMEOUT=3s
DAEMON_IDLE_TIMEOUT=60s

# Voice defaults
DEFAULT_SPEAKER=p245
HAL_SPEAKER=p254
MAX_RETRIES=2
DRAG_THRESHOLD_SECONDS=3

# Performance tuning
HTTP_TIMEOUT_SECONDS=30
HTTP_RESPONSE_HEADER_TIMEOUT_SECONDS=10
MAX_IDLE_CONNECTIONS=100
MAX_IDLE_CONNECTIONS_PER_HOST=20
IDLE_CONNECTION_TIMEOUT_SECONDS=300

# File system and logging
TMP_AUDIO_DIR=/tmp/tts_pipeline_cache
LOG_LEVEL=INFO
LOG_FILE=/var/log/tts_pipeline.log

# Kubernetes deployment helpers
TTS_NAMESPACE=tts
TTS_DEPLOYMENT_NAME=coqui-tts
KUBECTL_CONTEXT=default
