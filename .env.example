# Core TTS endpoints
TTS_LOADBALANCER_URL=http://localhost:5000
TTS_DIRECT_URL=http://localhost:5001
TTS_HEALTH_ENDPOINT=/health

# Daemon runtime
DAEMON_HOST=0.0.0.0
DAEMON_PORT=8091
DEFAULT_SPEAKER=p335
HAL_SPEAKER=p254
MAX_RETRIES=3
DRAG_THRESHOLD_SECONDS=0.30

# Kubernetes deployment helpers
TTS_NAMESPACE=tts
TTS_DEPLOYMENT_NAME=coqui-tts
KUBECTL_CONTEXT=default
