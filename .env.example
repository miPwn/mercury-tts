# Core TTS endpoints
TTS_LOADBALANCER_URL=http://localhost:5000
TTS_DIRECT_URL=http://localhost:5001
TTS_HEALTH_ENDPOINT=/health

# Daemon runtime
DAEMON_HOST=0.0.0.0
DAEMON_PORT=8091
DEFAULT_SPEAKER=p335
HAL_SPEAKER=p254
MAX_RETRIES=3
DRAG_THRESHOLD_SECONDS=0.30
LOG_LEVEL=info
LOGCITY_ENABLED=1
LOGCITY_ENDPOINT=http://falcon.mipwn.local:3100/loki/api/v1/push
LOGCITY_TENANT_ID=halo-system
LOGCITY_ENV=dev
LOGCITY_BUFFER_SIZE=4096
LOGCITY_BATCH_SIZE=64
LOGCITY_FLUSH_INTERVAL_MS=750
LOGCITY_REQUEST_TIMEOUT_MS=1500

# Kubernetes deployment helpers
TTS_NAMESPACE=tts
TTS_DEPLOYMENT_NAME=coqui-tts
KUBECTL_CONTEXT=default
