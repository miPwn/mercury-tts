# Core TTS endpoints
TTS_LOADBALANCER_URL=http://127.0.0.1:5002/api/tts
TTS_DIRECT_URL=http://127.0.0.1:5002/api/tts
TTS_HEALTH_ENDPOINT=http://127.0.0.1:5002/health

# Daemon runtime
DAEMON_HOST=0.0.0.0
DAEMON_PORT=8091
TTS_BIND_ADDR=0.0.0.0:8091
DEFAULT_SPEAKER=p335
HAL_SPEAKER=p254
MAX_RETRIES=3
DRAG_THRESHOLD_SECONDS=0.30
WARMUP_CONNECTION_COUNT=5
MAX_CONCURRENT_GENERATION=10
PLAYBACK_MODE=aplay
PLAYBACK_DEVICE=default
TTS_TMP_AUDIO_DIR=/tmp/streaming_safe_daemon
HTTP_TIMEOUT_SECONDS=30
HTTP_RESPONSE_HEADER_TIMEOUT_SECONDS=10
MAX_IDLE_CONNECTIONS=100
MAX_IDLE_CONNECTIONS_PER_HOST=20
IDLE_CONNECTION_TIMEOUT_SECONDS=300
DAEMON_READ_TIMEOUT=2
DAEMON_WRITE_TIMEOUT=30
DAEMON_IDLE_TIMEOUT=60
VBAN_TARGET_IP=192.168.1.100
VBAN_TARGET_PORT=6980
VBAN_STREAM_NAME=Falcon
HAL_DOTMATRIX_ENABLED=0
HAL_DOTMATRIX_QUEUE_DIR=/tmp/halo-dotmatrix/queue
HAL_DOTMATRIX_WAV_DIR=/tmp/halo-dotmatrix/wav
LOG_LEVEL=info
LOGCITY_ENABLED=1
LOGCITY_ENDPOINT=http://falcon.mipwn.local:3100/loki/api/v1/push
LOGCITY_TENANT_ID=halo-system
LOGCITY_ENV=dev
LOGCITY_BUFFER_SIZE=4096
LOGCITY_BATCH_SIZE=64
LOGCITY_FLUSH_INTERVAL_MS=750
LOGCITY_REQUEST_TIMEOUT_MS=1500

# Kubernetes deployment helpers
TTS_NAMESPACE=tts
TTS_DEPLOYMENT_NAME=coqui-tts
KUBECTL_CONTEXT=default
