{
  "repo": "mercury-tts",
  "deploymentModel": {
    "runtimeTargets": [
      {
        "name": "falcon-halo-runtime",
        "environment": "falcon-host",
        "kind": "script",
        "status": "active",
        "liveTarget": "/usr/local/bin/halo",
        "sourcePaths": [
          "halo",
          "scripts/deploy-falcon-runtime.sh",
          "tools/halo.ps1",
          "tools/halo-wsl-client.sh",
          "tools/install-halo-wsl-client.sh"
        ]
      },
      {
        "name": "falcon-hal-runtime",
        "environment": "falcon-host",
        "kind": "script",
        "status": "active",
        "liveTarget": "/usr/local/bin/hal",
        "sourcePaths": [
          "hal",
          "scripts/deploy-falcon-runtime.sh"
        ]
      },
      {
        "name": "falcon-hal-tts-daemon",
        "environment": "falcon-host",
        "kind": "service",
        "status": "active",
        "liveTarget": "systemd:hal-tts.service",
        "sourcePaths": [
          "streaming_safe_daemon.go",
          "hal-tts.service"
        ]
      },
      {
        "name": "falcon-k3s-hal-tts",
        "environment": "falcon-k3s",
        "kind": "k8s",
        "status": "secondary",
        "clusterTarget": "tts/hal-tts",
        "sourcePaths": [
          "Dockerfile.hal-tts",
          "deploy-hal-tts.sh",
          "docs/deployment-workflow.md",
          "k8s/hal-tts-deployment.yaml"
        ]
      },
      {
        "name": "archos-primary-xtts",
        "environment": "archos-host",
        "kind": "api",
        "status": "external",
        "liveTarget": "http://192.168.1.165:5003/api/tts",
        "sourcePaths": [
          "halo"
        ]
      },
      {
        "name": "windows-halo-wrapper",
        "environment": "windows-client",
        "kind": "wrapper",
        "status": "active",
        "liveTarget": "ssh falcon:/usr/local/bin/halo",
        "sourcePaths": [
          "tools/halo.ps1",
          "tools/install-xtts-portforwards.ps1",
          "tools/watch-xtts-portforwards.ps1"
        ]
      }
    ],
    "integrationPoints": [
      {
        "name": "queue-playback-http",
        "targetRepo": "tts-player-queue-service",
        "kind": "http",
        "pathOrEndpoint": "http://127.0.0.1:18080/api/tts/play",
        "sourcePaths": [
          "halo"
        ]
      },
      {
        "name": "hal-sysmon-latency-state",
        "targetRepo": "hal-sysmon",
        "kind": "state",
        "pathOrEndpoint": "/mnt/dkstorage/hal-system-monitor/state/halo/latency-metrics.json",
        "sourcePaths": [
          "halo"
        ]
      },
      {
        "name": "dotmatrix-spool",
        "targetRepo": "hal-display",
        "kind": "filesystem",
        "pathOrEndpoint": "/tmp/halo-dotmatrix/queue",
        "sourcePaths": [
          "halo"
        ]
      }
    ]
  },
  "guardrails": {
    "changeSets": [
      {
        "name": "halo-runtime-and-wrappers",
        "triggers": [
          "halo",
          "hal",
          "scripts/deploy-falcon-runtime.sh",
          "tools/halo.ps1",
          "tools/halo-wsl-client.sh",
          "tools/install-halo-wsl-client.sh",
          "tools/install-xtts-portforwards.ps1",
          "tools/watch-xtts-portforwards.ps1"
        ],
        "requiresTouch": [
          "deployment-contract.json"
        ]
      },
      {
        "name": "hal-host-daemon",
        "triggers": [
          "streaming_safe_daemon.go",
          "hal-tts.service"
        ],
        "requiresTouch": [
          "deployment-contract.json"
        ]
      },
      {
        "name": "k8s-and-runtime-deployments",
        "triggers": [
          "Dockerfile.hal-tts",
          "deploy-hal-tts.sh",
          "docs/deployment-workflow.md",
          "k8s/hal-tts-deployment.yaml",
          "k8s/coqui-xtts-deployment.yaml"
        ],
        "requiresTouch": [
          "deployment-contract.json"
        ]
      }
    ]
  }
}